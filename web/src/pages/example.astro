---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Example collab letter — Dear User"
  description="An example collaboration letter from Dear User. Score, persona, friction, recommendations — in the voice of the product."
  active="example"
>

<style>
  .letter-wrap { padding: 64px 0 48px; }
  .letter-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .sample-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding: 14px 18px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-left: 3px solid var(--c-action-600);
    border-radius: 8px;
    margin-bottom: 48px;
    font-size: 13px;
    color: var(--c-ink-700);
  }
  .sample-banner strong { color: var(--c-ink-900); font-weight: 600; }
  .sample-banner a {
    color: var(--c-action-600);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }

  .letter-date {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-ink-400);
    margin-bottom: 20px;
  }
  .letter-greeting {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(40px, 6vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 28px;
    color: var(--c-ink-900);
  }
  .letter-body p {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 19px;
    line-height: 1.6;
    color: var(--c-ink-700);
    margin: 0 0 18px;
  }
  .letter-body p strong { color: var(--c-ink-900); font-weight: 500; }
  .letter-body em { font-style: italic; }

  /* Scores --------------------------------------------------------- */
  .scores {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin: 36px 0;
  }
  @media (max-width: 640px) { .scores { grid-template-columns: 1fr; } }
  .score-tile {
    border: 1px solid var(--c-paper-200);
    border-radius: 12px;
    padding: 20px;
    background: var(--c-paper-50);
  }
  .score-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ink-500);
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .score-dot {
    width: 6px; height: 6px; border-radius: 50%;
    flex-shrink: 0;
  }
  .score-dot.good { background: var(--c-good); }
  .score-dot.warn { background: var(--c-warn); }
  .score-dot.bad { background: var(--c-bad); }
  .score-num {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 56px;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .score-num.good { color: var(--c-good); }
  .score-num.warn { color: var(--c-warn); }
  .score-num.bad { color: var(--c-bad); }
  .score-hint {
    margin-top: 12px;
    font-size: 13px;
    color: var(--c-ink-500);
    line-height: 1.5;
  }

  /* Section heading inside letter --------------------------------- */
  .letter-body h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 28px;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--c-ink-900);
    margin: 48px 0 14px;
  }
  .letter-body h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 20px;
    line-height: 1.3;
    color: var(--c-ink-900);
    margin: 28px 0 10px;
  }

  /* Persona card --------------------------------------------------- */
  .persona {
    margin: 28px 0;
    padding: 24px;
    background: var(--c-accent-100);
    border: 1px solid var(--c-accent-100);
    border-radius: 12px;
  }
  .persona-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-accent-600);
    margin-bottom: 8px;
  }
  .persona-name {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 24px;
    color: var(--c-ink-900);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }
  .persona-traits {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 14px;
  }
  .trait-pill {
    font-size: 12px;
    padding: 4px 10px;
    background: var(--c-paper-50);
    border: 1px solid var(--c-paper-200);
    border-radius: 999px;
    color: var(--c-ink-700);
  }

  /* Findings list ------------------------------------------------- */
  .finding {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 14px;
    padding: 18px 0;
    border-bottom: 1px solid var(--c-paper-200);
  }
  .finding:last-child { border-bottom: 0; }
  .finding-num {
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
    color: var(--c-ink-400);
    padding-top: 2px;
  }
  .finding-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 19px;
    color: var(--c-ink-900);
    font-weight: 500;
    margin: 0 0 6px;
    line-height: 1.35;
  }
  .finding-body {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 16px;
    color: var(--c-ink-700);
    line-height: 1.55;
    margin: 0;
  }
  .finding-tag {
    display: inline-block;
    font-family: 'Geist', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 4px;
    margin-right: 8px;
    vertical-align: middle;
  }
  .finding-tag.pattern { background: var(--c-action-100); color: var(--c-action-700); }
  .finding-tag.win { background: color-mix(in srgb, var(--c-good) 14%, transparent); color: var(--c-good); }
  .finding-tag.risk { background: color-mix(in srgb, var(--c-bad) 14%, transparent); color: var(--c-bad); }

  /* Recommendation card ------------------------------------------- */
  .rec {
    margin: 20px 0;
    padding: 22px 24px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 12px;
  }
  .rec-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .rec-badge {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
    background: var(--c-action-100);
    color: var(--c-action-700);
    font-weight: 600;
  }
  .rec-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 19px;
    color: var(--c-ink-900);
    font-weight: 500;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .rec-body {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 16px;
    color: var(--c-ink-700);
    line-height: 1.55;
    margin: 0 0 14px;
  }
  .rec pre {
    background: var(--c-paper-50);
    border: 1px solid var(--c-paper-200);
    border-radius: 8px;
    padding: 14px 16px;
    overflow-x: auto;
    font-family: 'Geist Mono', monospace;
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--c-ink-700);
    margin: 0;
  }
  .rec pre .k { color: var(--c-action-600); }

  /* Signature ----------------------------------------------------- */
  .signature {
    margin-top: 48px;
    padding-top: 28px;
    border-top: 1px solid var(--c-paper-200);
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--c-ink-700);
  }
  .signature svg { width: 28px; height: 28px; }
  .signature-name {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 20px;
    color: var(--c-ink-900);
    letter-spacing: -0.01em;
  }

  .letter-cta {
    margin-top: 48px;
    padding: 28px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 14px;
    text-align: center;
  }
  .letter-cta h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 24px;
    color: var(--c-ink-900);
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }
  .letter-cta p {
    color: var(--c-ink-700);
    margin: 0 0 18px;
    font-size: 15px;
  }
  .letter-cta .install-inline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--c-paper-50);
    border: 1px solid var(--c-paper-200);
    border-radius: 8px;
    padding: 10px 14px;
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
    color: var(--c-ink-900);
  }
  .letter-cta .install-inline .prompt { color: var(--c-ink-400); }
</style>

<section class="letter-wrap">
  <div class="letter-inner">

    <div class="sample-banner">
      <span>
        <strong>
          
          Example letter.
        </strong>
        
         Your own will be about you and your setup.
      </span>
      <a href="#get-one">
        
        Get your own →
      </a>
    </div>

    <div class="letter-date">
      
      21 April 2026 · Collaboration letter
    </div>

    <h1 class="letter-greeting">
      
      Dear Sam,
    </h1>

    <div class="letter-body">
      <p>
        
        I sat with your setup tonight and read through everything — <strong>CLAUDE.md</strong>, memory, hooks, skills and recent sessions. I want to share three things. One that makes me glad, one I'm puzzled by, and one concrete change I think you should make tomorrow.
      </p>

      <div class="scores">
        <div class="score-tile">
          <div class="score-label">
            <span class="score-dot good"></span>
            Collaboration
          </div>
          <div class="score-num good">87</div>
          <div class="score-hint">
            
            Clear rules, fast feedback, strong memory.
          </div>
        </div>
        <div class="score-tile">
          <div class="score-label">
            <span class="score-dot warn"></span>
            System health
          </div>
          <div class="score-num warn">74</div>
          <div class="score-hint">
            
            Some overlap between your skills — see recommendation #2.
          </div>
        </div>
        <div class="score-tile">
          <div class="score-label">
            <span class="score-dot good"></span>
            Security
          </div>
          <div class="score-num good">92</div>
          <div class="score-hint">
            
            Your secrets are where they should be.
          </div>
        </div>
      </div>

      <h2>
        
        Your persona
      </h2>
      <div class="persona">
        <div class="persona-label">
          Agent archetype
        </div>
        <div class="persona-name">
          
          The Solo Builder
        </div>
        <p style="font-family:'Fraunces',Georgia,serif;font-size:16px;color:var(--c-ink-700);line-height:1.55;margin:0;">
          
          You're building one product on the side of a day job. Your agent isn't a colleague — it's a scaffold. You optimize for <em>momentum</em>, not elegance. Your CLAUDE.md grows with every Friday-night lesson.
        </p>
        <div class="persona-traits">
          <span class="trait-pill">
            Pragmatic
          </span>
          <span class="trait-pill">
            Iterative
          </span>
          <span class="trait-pill">
            Memory-first
          </span>
          <span class="trait-pill">
            Learns from mistakes
          </span>
        </div>
      </div>

      <h2>
        
        What I saw
      </h2>

      <div class="finding">
        <div class="finding-num">01</div>
        <div>
          <h3 class="finding-title">
            <span class="finding-tag win">
              Strength
            </span>
            
            Your feedback loop actually closes
          </h3>
          <p class="finding-body">
            
            Most of your recommendations from the last two weeks have actually landed somewhere — <em>shipped</em>, <em>abandoned</em> or <em>evolved</em>. That's unusually high. Most setups produce recommendations that never land. Your habit of marking outcomes and consolidating weekly is doing the work.
          </p>
        </div>
      </div>

      <div class="finding">
        <div class="finding-num">02</div>
        <div>
          <h3 class="finding-title">
            <span class="finding-tag pattern">
              Pattern
            </span>
            
            The same shell script is called from many skills
          </h3>
          <p class="finding-body">
            
            Several skills parse output from the same CLI in their own way. It's repetition that turns fragile every time the script moves or changes format. It's screaming "MCP server". I have a migration sketch further down.
          </p>
        </div>
      </div>

      <div class="finding">
        <div class="finding-num">03</div>
        <div>
          <h3 class="finding-title">
            <span class="finding-tag risk">
              Risk
            </span>
            
            Rule conflict in your hook layer
          </h3>
          <p class="finding-body">
            
            A rule in your CLAUDE.md says one thing, and a hook does the opposite. It's the kind of incoherence you only notice on a Friday night, when the build suddenly commits something that shouldn't have been committed.
          </p>
        </div>
      </div>

      <h2>
        
        What I recommend
      </h2>

      <div class="rec">
        <div class="rec-head">
          <span class="rec-badge">
            Recommendation #1
          </span>
          <span style="font-family:'Geist Mono',monospace;font-size:11px;color:var(--c-ink-400);">
            
            ~10 min · High leverage
          </span>
        </div>
        <h4 class="rec-title">
          
          Resolve the rule conflict — one line
        </h4>
        <p class="rec-body">
          
          Either the hook respects the rule, or the rule needs nuance. Start by changing the hook — it's the smallest change that buys the most peace of mind: the build shouldn't be able to route around your own quality checks.
        </p>
        <pre><span class="k">-</span> # hook bypasses your own rule
<span class="k">+</span> # hook honors your own rule</pre>
      </div>

      <div class="rec">
        <div class="rec-head">
          <span class="rec-badge">
            Recommendation #2
          </span>
          <span style="font-family:'Geist Mono',monospace;font-size:11px;color:var(--c-ink-400);">
            
            ~2 hours · Removes a lot of repetition
          </span>
        </div>
        <h4 class="rec-title">
          
          Wrap your repeated CLI as an MCP server
        </h4>
        <p class="rec-body">
          
          Several skills call the same CLI and parse its output in their own way. If you wrap it as an MCP server, your skills can just call a structured tool and become independent of path and shell-escaping. Same pattern you already use for Dear User itself.
        </p>
        <pre><span class="k">+</span> npx create-mcp-server my-cli
<span class="k">+</span> # move subcommands → tools/
<span class="k">+</span> # update skills to call mcp__my-cli__*</pre>
      </div>

      <div class="rec">
        <div class="rec-head">
          <span class="rec-badge">
            Recommendation #3
          </span>
          <span style="font-family:'Geist Mono',monospace;font-size:11px;color:var(--c-ink-400);">
            
            ~5 min · Hygiene
          </span>
        </div>
        <h4 class="rec-title">
          
          Default your MCP servers to read-only
        </h4>
        <p class="rec-body">
          
          Several of your MCP servers run in write mode, but are used almost exclusively read-only. Flip them to read-only by default and explicitly ask for write when you need it. Smaller blast radius, same workflow.
        </p>
      </div>

      <p style="margin-top: 40px;">
        
        If you land #1 tomorrow and #2 before the weekend, the score will be 94+ at the next scan. I'll check in again Sunday. Have a calm week.
      </p>

      <div class="signature">
        <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="20" cy="20" r="20" fill="#EC5329" />
          <path d="M 11 22 Q 20 32 29 22" stroke="var(--c-smile-fill)" stroke-width="2.5" stroke-linecap="round" fill="none" />
        </svg>
        <span class="signature-name">Dear User</span>
      </div>
    </div>

    <div class="letter-cta" id="get-one">
      <h3>
        
        Get your own letter.
      </h3>
      <p>
        
        One line installs the whole thing. The scan runs locally. No data leaves your machine.
      </p>
      <div class="install-inline">
        <span class="prompt">$</span>
        <span>claude mcp add --scope user dearuser -- npx -y @poisedhq/dearuser-mcp@latest</span>
      </div>
    </div>

  </div>
</section>

</Layout>
