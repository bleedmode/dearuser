---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Dear User — Audit din Claude Code-opsætning" active="home">

<style>
  /* Hero ----------------------------------------------------------- */
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 88px 24px 80px;
    position: relative;
  }
  .hero-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-action-600);
    margin-bottom: 24px;
  }
  .hero h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(40px, 7vw, 76px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--c-ink-900);
    margin: 0;
    max-width: 820px;
  }
  .hero h1 .accent { color: var(--c-action-600); }
  .hero-sub {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(17px, 1.7vw, 19px);
    color: var(--c-ink-700);
    line-height: 1.55;
    max-width: 620px;
    margin: 28px 0 36px;
  }
  .hero-sub p { margin: 0 0 12px; }
  .hero-sub p:last-child { margin-bottom: 0; }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .hero-example-link {
    color: var(--c-ink-500);
    text-decoration: none;
    font-size: 14px;
    border-bottom: 1px solid var(--c-paper-200);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .hero-example-link:hover {
    color: var(--c-ink-900);
    border-color: var(--c-ink-500);
  }

  /* Install block --------------------------------------------------- */
  .install {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 10px;
    padding: 14px 18px;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 14px;
    cursor: pointer;
    color: var(--c-ink-900);
    transition: border-color 0.15s, background 0.15s;
    user-select: none;
  }
  .install:hover { border-color: var(--c-accent-500); background: var(--c-paper-50); }
  .install .prompt { color: var(--c-ink-400); }
  .install .cmd { color: var(--c-ink-900); }
  .install .copy {
    margin-left: 6px;
    font-family: 'Geist', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-ink-500);
    padding: 3px 8px;
    border-radius: 4px;
    background: var(--c-paper-200);
    transition: background 0.15s, color 0.15s;
  }
  .install:hover .copy { background: var(--c-action-100); color: var(--c-action-700); }

  /* Quick-facts row under hero -------------------------------------- */
  .hero-facts {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 22px 32px;
    margin-top: 36px;
    font-size: 13px;
    color: var(--c-ink-500);
  }
  .hero-facts .dot {
    color: var(--c-action-600);
    margin-right: 8px;
  }

  /* Features grid --------------------------------------------------- */
  .features-section {
    padding: 72px 0 48px;
    border-top: 1px solid var(--c-paper-200);
  }
  .section-head {
    max-width: 720px;
    margin: 0 auto 40px;
    padding: 0 24px;
  }
  .section-eyebrow {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ink-400);
    margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--c-ink-900);
    margin: 0;
  }
  .section-sub {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 18px;
    color: var(--c-ink-700);
    line-height: 1.55;
    margin: 12px 0 0;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (max-width: 900px) {
    .features-grid { grid-template-columns: 1fr; }
  }
  .feature {
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 14px;
    padding: 28px;
    transition: border-color 0.15s, transform 0.15s;
    display: flex;
    flex-direction: column;
  }
  .feature:hover {
    border-color: var(--c-accent-500);
    transform: translateY(-2px);
  }
  .feature-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 9px;
    border-radius: 5px;
    margin-bottom: 18px;
    background: var(--c-action-100);
    color: var(--c-action-700);
    align-self: flex-start;
  }
  .feature h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 10px;
    color: var(--c-ink-900);
  }
  .feature p {
    margin: 0 0 16px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--c-ink-700);
  }
  .feature ul {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
    font-size: 14px;
    color: var(--c-ink-700);
    line-height: 1.55;
  }
  .feature ul li {
    padding-left: 18px;
    position: relative;
    margin-bottom: 6px;
  }
  .feature ul li:before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--c-action-600);
  }
  .feature-cmd {
    display: inline-block;
    font-family: 'Geist Mono', monospace;
    font-size: 12.5px;
    background: var(--c-paper-50);
    border: 1px solid var(--c-paper-200);
    color: var(--c-ink-700);
    padding: 7px 11px;
    border-radius: 6px;
    margin-top: auto;
    align-self: flex-start;
  }
  .feature-cmd .fn { color: var(--c-ink-900); }

  /* "Also included" row (onboard/wrapped/history) ------------------- */
  .also {
    max-width: 1080px;
    margin: 48px auto 0;
    padding: 0 24px;
  }
  .also-title {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ink-400);
    text-align: center;
    margin-bottom: 20px;
  }
  .also-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 760px) { .also-grid { grid-template-columns: 1fr; } }
  .also-item {
    background: var(--c-paper-50);
    border: 1px solid var(--c-paper-200);
    border-radius: 10px;
    padding: 18px 20px;
  }
  .also-item h4 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 17px;
    margin: 0 0 4px;
    color: var(--c-ink-900);
  }
  .also-item p {
    margin: 0;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--c-ink-500);
  }

  /* Share section --------------------------------------------------- */
  .share {
    padding: 80px 0;
    border-top: 1px solid var(--c-paper-200);
  }
  .share-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  @media (max-width: 900px) {
    .share-inner { grid-template-columns: 1fr; gap: 32px; }
  }
  .share-copy h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--c-ink-900);
    margin: 0 0 16px;
  }
  .share-copy p {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 17px;
    line-height: 1.55;
    color: var(--c-ink-700);
    margin: 0 0 14px;
  }
  .share-copy .share-url {
    display: inline-block;
    font-family: 'Geist Mono', monospace;
    font-size: 13.5px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    padding: 8px 12px;
    border-radius: 8px;
    margin-top: 12px;
    color: var(--c-ink-700);
  }
  .share-copy .share-url .path { color: var(--c-action-600); }
  .share-note {
    font-size: 13px;
    color: var(--c-ink-500);
    margin-top: 16px !important;
    line-height: 1.55;
  }

  /* Share card mock ------------------------------------------------- */
  .share-card-mock {
    aspect-ratio: 1200 / 630;
    border: 1px solid var(--c-paper-200);
    border-radius: 14px;
    background: linear-gradient(135deg, var(--c-paper-100) 0%, var(--c-paper-50) 100%);
    padding: 36px 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 40px -20px rgba(31, 26, 20, 0.15);
  }
  .share-card-mock .sc-mark {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 18px;
    color: var(--c-ink-900);
  }
  .share-card-mock .sc-mark svg { width: 22px; height: 22px; }
  .share-card-mock .sc-body {
    display: flex;
    align-items: baseline;
    gap: 18px;
  }
  .share-card-mock .sc-score {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: clamp(56px, 11vw, 96px);
    line-height: 1;
    color: var(--c-action-600);
    letter-spacing: -0.03em;
  }
  .share-card-mock .sc-score-unit {
    font-family: 'Geist Mono', monospace;
    font-size: 14px;
    color: var(--c-ink-400);
  }
  .share-card-mock .sc-label {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: clamp(16px, 1.8vw, 20px);
    color: var(--c-ink-700);
    max-width: 60%;
  }
  .share-card-mock .sc-foot {
    display: flex;
    justify-content: space-between;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-ink-400);
  }

  /* Social proof placeholder --------------------------------------- */
  .social-proof {
    padding: 56px 24px;
    border-top: 1px solid var(--c-paper-200);
    text-align: center;
  }
  .social-proof .sp-label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ink-400);
    margin-bottom: 20px;
  }
  .social-proof .sp-placeholder {
    max-width: 720px;
    margin: 0 auto;
    padding: 28px 24px;
    border: 1px dashed var(--c-paper-300);
    border-radius: 12px;
    color: var(--c-ink-500);
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 16px;
    line-height: 1.55;
  }

  /* How it works ---------------------------------------------------- */
  .how {
    padding: 72px 0;
    border-top: 1px solid var(--c-paper-200);
  }
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (max-width: 760px) { .steps { grid-template-columns: 1fr; } }
  .step {
    padding: 24px;
    border: 1px solid var(--c-paper-200);
    border-radius: 12px;
    background: var(--c-paper-100);
  }
  .step-num {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.15em;
    color: var(--c-action-600);
    margin-bottom: 14px;
  }
  .step h4 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 22px;
    margin: 0 0 8px;
    letter-spacing: -0.01em;
    color: var(--c-ink-900);
  }
  .step p {
    margin: 0 0 14px;
    font-size: 14px;
    color: var(--c-ink-700);
    line-height: 1.55;
  }
  .step code {
    display: block;
    font-family: 'Geist Mono', monospace;
    font-size: 12.5px;
    background: var(--c-paper-50);
    border: 1px solid var(--c-paper-200);
    color: var(--c-ink-900);
    padding: 10px 12px;
    border-radius: 6px;
    word-break: break-all;
  }

  /* Pull quote ------------------------------------------------------ */
  .pullquote {
    padding: 72px 0;
    border-top: 1px solid var(--c-paper-200);
    text-align: center;
  }
  .pullquote blockquote {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 3.5vw, 36px);
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--c-ink-900);
    max-width: 720px;
    margin: 0 auto;
    padding: 0 32px;
    border-left: 3px solid var(--c-action-600);
  }
  .pullquote cite {
    display: block;
    margin-top: 18px;
    font-style: normal;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-ink-400);
  }
</style>

<!-- Hero ------------------------------------------------------------- -->
<section class="hero">
  <div class="hero-eyebrow">
    <span class="lang-da">Din AI-samarbejdspartner</span>
    <span class="lang-en">Your AI collaboration partner</span>
  </div>
  <h1>
    <span class="lang-da">Kære bruger,<br/>hvordan går samarbejdet med din <span class="accent">agent?</span></span>
    <span class="lang-en">Dear User,<br/>how's the collaboration with your <span class="accent">agent?</span></span>
  </h1>

  <div class="hero-sub">
    <p>
      <span class="lang-da">I år vil du bruge flere timer med din AI-agent end med de fleste mennesker i dit liv. Dear User er bygget til at få det bedste ud af de timer.</span>
      <span class="lang-en">This year, you'll spend more hours with your AI agent than with most people in your life. Dear User was built to make the most of those hours.</span>
    </p>
  </div>

  <div class="hero-actions">
    <div class="install" id="install-cta" data-analytics="install-copy" title="Click to copy">
      <span class="prompt">$</span>
      <span class="cmd">claude mcp add dearuser -- npx dearuser-mcp</span>
      <span class="copy" id="copy-label">
        <span class="lang-da">Kopiér</span><span class="lang-en">Copy</span>
      </span>
    </div>
    <a href="/example" class="hero-example-link">
      <span class="lang-da">Eller se et eksempel →</span>
      <span class="lang-en">Or see an example →</span>
    </a>
  </div>
</section>

<script is:inline>
  var cta = document.getElementById('install-cta');
  var label = document.getElementById('copy-label');
  var cmd = 'claude mcp add dearuser -- npx dearuser-mcp';
  if (cta) {
    cta.addEventListener('click', function () {
      if (!navigator.clipboard) return;
      navigator.clipboard.writeText(cmd).then(function () {
        if (!label) return;
        var html = label.innerHTML;
        label.innerHTML = '<span class="lang-da">Kopieret</span><span class="lang-en">Copied</span>';
        setTimeout(function () { label.innerHTML = html; }, 1600);
      }).catch(function () {});
    });
  }
</script>

<!-- Features --------------------------------------------------------- -->
<section class="features-section" id="features">
  <div class="section-head">
    <div class="section-eyebrow">
      <span class="lang-da">Det får du</span><span class="lang-en">What you get</span>
    </div>
    <h2 class="section-title">
      <span class="lang-da">Én MCP-server. Tre breve om din opsætning.</span>
      <span class="lang-en">One MCP Server. Three letters about your setup.</span>
    </h2>
    <p class="section-sub">
      <span class="lang-da">Dear User læser din opsætning som en ny kollega der faktisk er opmærksom — og skriver tilbage om hvor du gentager dig selv, hvor der er nøgler på afveje, og hvor din opsætning stille driver fra hinanden.</span>
      <span class="lang-en">Dear User reads your setup like a new colleague who actually pays attention — then writes back about where you're repeating yourself, where keys are leaking, and where your setup is quietly drifting apart.</span>
    </p>
  </div>

  <div class="features-grid">
    <!-- Collab -->
    <div class="feature">
      <span class="feature-badge">
        <span class="lang-da">Samarbejde</span><span class="lang-en">Collab</span>
      </span>
      <h3>
        <span class="lang-da">Hvordan I arbejder sammen.</span>
        <span class="lang-en">How you two work together.</span>
      </h3>
      <p>
        <span class="lang-da">En score for samarbejdet, din agents "arketype" og konkrete forslag — ikke bare "overvej bedre instruktioner".</span>
        <span class="lang-en">A score for your collaboration, your agent's "archetype", and concrete suggestions — not just "consider better instructions".</span>
      </p>
      <ul>
        <li><span class="lang-da">Fanger mønstre: rettelser du gør igen og igen</span><span class="lang-en">Catches patterns: corrections you make over and over</span></li>
        <li><span class="lang-da">Forslag med kode-snippets klar til paste</span><span class="lang-en">Suggestions with code snippets ready to paste</span></li>
        <li><span class="lang-da">Fortæller hvor din opsætning er stærk</span><span class="lang-en">Tells you where your setup is strong</span></li>
      </ul>
      <span class="feature-cmd"><span class="fn">mcp__dearuser__collab</span></span>
    </div>

    <!-- Security — emphasize secrets -->
    <div class="feature">
      <span class="feature-badge">
        <span class="lang-da">Sikkerhed</span><span class="lang-en">Security</span>
      </span>
      <h3>
        <span class="lang-da">Leder efter nøgler du har glemt.</span>
        <span class="lang-en">Looks for keys you forgot.</span>
      </h3>
      <p>
        <span class="lang-da">Scanner dine Claude-filer for lækkede API-nøgler (OpenAI, Anthropic, GitHub, AWS, Stripe og 8 andre typer) og samler signaler fra de platforme du allerede bruger.</span>
        <span class="lang-en">Scans your Claude files for leaked API keys (OpenAI, Anthropic, GitHub, AWS, Stripe and 8 other types) and pulls signals from the platforms you already use.</span>
      </p>
      <ul>
        <li><span class="lang-da">12 typer hemmeligheder fanget i instruktioner, memory, hooks og skills</span><span class="lang-en">12 secret types caught in instructions, memory, hooks and skills</span></li>
        <li><span class="lang-da">Henter advarsler fra GitHub, Supabase, npm og Vercel — når du har tokens opsat</span><span class="lang-en">Pulls warnings from GitHub, Supabase, npm and Vercel — when you've set up tokens</span></li>
        <li><span class="lang-da">Fanger regler der modsiger hinanden (fx "force-push aldrig" + en hook der gør det)</span><span class="lang-en">Catches rules that contradict each other (e.g. "never force-push" + a hook that does)</span></li>
      </ul>
      <span class="feature-cmd"><span class="fn">mcp__dearuser__security</span></span>
    </div>

    <!-- Health -->
    <div class="feature">
      <span class="feature-badge">
        <span class="lang-da">System-sundhed</span><span class="lang-en">Health</span>
      </span>
      <h3>
        <span class="lang-da">Hvad er gået i stykker?</span>
        <span class="lang-en">What's quietly broken?</span>
      </h3>
      <p>
        <span class="lang-da">Tegner et kort over din opsætning og finder de stille problemer: skills ingen kalder, jobs der skriver til filer ingen læser, regler der dublerer hinanden.</span>
        <span class="lang-en">Draws a map of your setup and surfaces the silent issues: skills nothing calls, jobs writing to files nothing reads, rules that duplicate each other.</span>
      </p>
      <ul>
        <li><span class="lang-da">Finder "orphan jobs" — output der aldrig bliver brugt</span><span class="lang-en">Finds "orphan jobs" — output that's never consumed</span></li>
        <li><span class="lang-da">Fanger overlap mellem skills, hooks og memory</span><span class="lang-en">Catches overlap between skills, hooks and memory</span></li>
        <li><span class="lang-da">Advarer før din opsætning bryder stille ned</span><span class="lang-en">Warns before your setup breaks silently</span></li>
      </ul>
      <span class="feature-cmd"><span class="fn">mcp__dearuser__health</span></span>
    </div>
  </div>

  <!-- Also included — smaller row ---------------------------------- -->
  <div class="also">
    <div class="also-title">
      <span class="lang-da">Plus tre til, med i pakken</span><span class="lang-en">Plus three more, included</span>
    </div>
    <div class="also-grid">
      <div class="also-item">
        <h4><span class="lang-da">Opstart</span><span class="lang-en">Onboard</span></h4>
        <p>
          <span class="lang-da">En guidet samtale der hjælper dig med at skrive din første CLAUDE.md.</span>
          <span class="lang-en">A guided conversation that helps you write your first CLAUDE.md.</span>
        </p>
      </div>
      <div class="also-item">
        <h4><span class="lang-da">Samarbejdet i tal</span><span class="lang-en">Wrapped</span></h4>
        <p>
          <span class="lang-da">Spotify Wrapped-stil stats om hvordan du og din agent faktisk arbejder.</span>
          <span class="lang-en">Spotify Wrapped-style stats on how you and your agent actually work.</span>
        </p>
      </div>
      <div class="also-item">
        <h4><span class="lang-da">Historik</span><span class="lang-en">History</span></h4>
        <p>
          <span class="lang-da">Se score-trenden over tid og hvad der blev bedre siden sidste scan.</span>
          <span class="lang-en">See the score trend over time and what improved since last scan.</span>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Share section ---------------------------------------------------- -->
<section class="share" id="share">
  <div class="share-inner">
    <div class="share-copy">
      <div class="section-eyebrow">
        <span class="lang-da">Del din rapport</span><span class="lang-en">Share your report</span>
