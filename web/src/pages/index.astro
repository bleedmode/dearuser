---
// Dear User — Landing page
// dearuser.ai
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dear User — Understand your AI collaboration</title>
  <meta name="description" content="An MCP server that scans your CLAUDE.md, memory, hooks, and sessions to diagnose how you and your AI agent actually work together." />
  <meta property="og:title" content="Dear User" />
  <meta property="og:description" content="Understand your AI collaboration. Analyze what's working, share what's not." />
  <meta property="og:url" content="https://dearuser.ai" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E💌%3C/text%3E%3C/svg%3E" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0a0a0a;
      --bg-elevated: #141414;
      --text: #f5f5f5;
      --text-dim: #888;
      --text-dimmer: #555;
      --accent-1: #8b5cf6;
      --accent-2: #06b6d4;
      --border: rgba(255,255,255,0.08);
      --border-hover: rgba(255,255,255,0.16);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      line-height: 1.5;
    }

    .container {
      max-width: 1080px;
      margin: 0 auto;
      padding: 0 24px;
    }

    /* Nav */
    nav {
      padding: 24px 0;
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo {
      font-weight: 800;
      font-size: 18px;
      letter-spacing: -0.02em;
    }
    .logo-mark {
      background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .nav-links {
      display: flex;
      gap: 28px;
      font-size: 14px;
    }
    .nav-links a {
      color: var(--text-dim);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--text); }

    /* Hero */
    .hero {
      padding: 120px 0 80px;
      text-align: center;
    }
    .hero-eyebrow {
      display: inline-block;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-dim);
      letter-spacing: 0.02em;
      margin-bottom: 24px;
      padding: 6px 12px;
      border: 1px solid var(--border);
      border-radius: 999px;
    }
    .hero h1 {
      font-size: clamp(42px, 7vw, 80px);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin-bottom: 24px;
    }
    .hero h1 .gradient {
      background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero p.sub {
      font-size: clamp(18px, 2vw, 22px);
      color: var(--text-dim);
      max-width: 640px;
      margin: 0 auto 48px;
      line-height: 1.5;
    }

    /* Install CTA */
    .install-block {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 16px 20px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 15px;
      cursor: pointer;
      transition: border-color 0.2s;
    }
    .install-block:hover { border-color: var(--border-hover); }
    .install-block .prompt { color: var(--text-dimmer); }
    .install-block .cmd { color: var(--text); }
    .install-block .copy {
      margin-left: 8px;
      font-size: 12px;
      color: var(--text-dim);
      padding: 4px 8px;
      background: rgba(255,255,255,0.04);
      border-radius: 6px;
      transition: all 0.2s;
    }
    .install-block:hover .copy {
      background: rgba(255,255,255,0.08);
      color: var(--text);
    }

    .secondary-cta {
      margin-top: 24px;
      font-size: 15px;
    }
    .secondary-cta a {
      color: var(--text-dim);
      text-decoration: none;
      border-bottom: 1px solid var(--border);
      transition: color 0.2s, border-color 0.2s;
    }
    .secondary-cta a:hover {
      color: var(--text);
      border-color: var(--text);
    }

    /* Features */
    .features {
      padding: 80px 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    @media (max-width: 720px) {
      .features { grid-template-columns: 1fr; }
    }
    .feature {
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 36px;
      transition: border-color 0.2s, transform 0.2s;
    }
    .feature:hover {
      border-color: var(--border-hover);
      transform: translateY(-2px);
    }
    .feature-badge {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 6px;
      margin-bottom: 20px;
    }
    .feature-badge.analyze {
      background: rgba(139, 92, 246, 0.12);
      color: var(--accent-1);
    }
    .feature-badge.wrapped {
      background: rgba(6, 182, 212, 0.12);
      color: var(--accent-2);
    }
    .feature h3 {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 12px;
    }
    .feature p {
      color: var(--text-dim);
      font-size: 15px;
      margin-bottom: 24px;
    }
    .feature-command {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      background: rgba(0,0,0,0.4);
      border: 1px solid var(--border);
      padding: 10px 14px;
      border-radius: 8px;
      color: var(--text);
      display: inline-block;
      margin-bottom: 20px;
    }
    .feature-command .fn {
      color: var(--accent-1);
    }
    .feature-command.wrapped .fn {
      color: var(--accent-2);
    }
    .feature-link {
      color: var(--text);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      border-bottom: 1px solid var(--text);
      padding-bottom: 2px;
    }

    /* How it works */
    .how {
      padding: 80px 0;
      border-top: 1px solid var(--border);
    }
    .how h2 {
      font-size: 36px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 48px;
      text-align: center;
    }
    .steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
    @media (max-width: 720px) {
      .steps { grid-template-columns: 1fr; }
    }
    .step {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .step-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      color: var(--text-dimmer);
      letter-spacing: 0.1em;
    }
    .step h4 {
      font-size: 18px;
      font-weight: 600;
      letter-spacing: -0.01em;
    }
    .step p {
      color: var(--text-dim);
      font-size: 14px;
    }
    .step code {
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      background: var(--bg-elevated);
      border: 1px solid var(--border);
      padding: 8px 10px;
      border-radius: 6px;
      color: var(--text);
      display: block;
      word-break: break-all;
    }

    /* Principles */
    .principles {
      padding: 80px 0;
      border-top: 1px solid var(--border);
      text-align: center;
    }
    .principles h2 {
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 48px;
    }
    .principle-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
      max-width: 800px;
      margin: 0 auto;
    }
    @media (max-width: 720px) {
      .principle-grid { grid-template-columns: 1fr; }
    }
    .principle h5 {
      font-size: 14px;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .principle p {
      color: var(--text-dim);
      font-size: 14px;
    }

    /* Footer */
    footer {
      padding: 48px 0 80px;
      border-top: 1px solid var(--border);
      color: var(--text-dimmer);
      font-size: 13px;
    }
    .footer-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 16px;
    }
    .footer-links {
      display: flex;
      gap: 24px;
    }
    .footer-links a {
      color: var(--text-dim);
      text-decoration: none;
    }
    .footer-links a:hover { color: var(--text); }
  </style>
</head>
<body>

<nav>
  <div class="container nav-inner">
    <div class="logo">
      <span class="logo-mark">Dear</span> User
    </div>
    <div class="nav-links">
      <a href="#features">Features</a>
      <a href="#install">Install</a>
      <a href="/demo">See example</a>
      <a href="https://github.com/bleedmode/dearuser" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</nav>

<section class="hero">
  <div class="container">
    <span class="hero-eyebrow">MCP server · Open source · Local</span>
    <h1>Understand your<br/><span class="gradient">AI collaboration.</span></h1>
    <p class="sub">Dear User scans your CLAUDE.md, memory, hooks, skills, and sessions — and tells you how you and your agent actually work together. Diagnose what's off. Share what's fun.</p>

    <div class="install-block" id="install-cta" title="Click to copy">
      <span class="prompt">$</span>
      <span class="cmd">claude mcp add dearuser -- npx dearuser-mcp</span>
      <span class="copy" id="copy-label">Copy</span>
    </div>

    <div class="secondary-cta">
      <a href="/demo">See an example Wrapped →</a>
    </div>
  </div>
</section>

<section class="features" id="features">
  <div class="container" style="grid-column: 1 / -1; display: contents;">
    <div class="feature">
      <span class="feature-badge analyze">Analyze</span>
      <h3>Find what's broken.</h3>
      <p>Scans your entire setup — CLAUDE.md, memory files, hooks, skills, settings, and session history. Produces a collaboration report with persona detection, scoring across 7 categories, and prioritized, evidence-rated recommendations.</p>
      <div class="feature-command"><span class="fn">mcp__dearuser__analyze</span></div>
    </div>

    <div class="feature">
      <span class="feature-badge wrapped">Wrapped</span>
      <h3>See what's fun.</h3>
      <p>Spotify Wrapped-style stats about how you and your agent actually work together. Your corrections, your "Don't"-rules ratio, your agent archetype, the system you've built. Shareable. Screenshotable.</p>
      <div class="feature-command wrapped"><span class="fn">mcp__dearuser__wrapped</span></div>
      <a href="/demo" class="feature-link">View example →</a>
    </div>
  </div>
</section>

<section class="how" id="install">
  <div class="container">
    <h2>Three steps.</h2>
    <div class="steps">
      <div class="step">
        <span class="step-num">01</span>
        <h4>Install</h4>
        <p>Add the MCP server to Claude Code.</p>
        <code>claude mcp add dearuser -- npx dearuser-mcp</code>
      </div>
      <div class="step">
        <span class="step-num">02</span>
        <h4>Analyze</h4>
        <p>In any Claude Code session, ask your agent:</p>
        <code>Run dearuser analyze</code>
      </div>
      <div class="step">
        <span class="step-num">03</span>
        <h4>Share</h4>
        <p>Generate your Wrapped and share the screenshot.</p>
        <code>Run dearuser wrapped</code>
      </div>
    </div>
  </div>
</section>

<section class="principles">
  <div class="container">
    <h2>How it works.</h2>
    <div class="principle-grid">
      <div class="principle">
        <h5>Local by default</h5>
        <p>Everything runs on your machine. No data leaves your setup.</p>
      </div>
      <div class="principle">
        <h5>Three sources</h5>
        <p>Your files, an external knowledge base, and a feedback loop that tracks what actually worked.</p>
      </div>
      <div class="principle">
        <h5>Concrete, not vague</h5>
        <p>Actual code and config to paste. Not "consider improving your memory system".</p>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="container footer-inner">
    <div>© 2026 Dear User · Made by <a href="https://poised.dk" style="color:var(--text-dim);text-decoration:none;border-bottom:1px solid var(--border);">Poised Venture Studio</a></div>
    <div class="footer-links">
      <a href="https://github.com/bleedmode/dearuser" target="_blank" rel="noopener">GitHub</a>
      <a href="https://github.com/bleedmode/dearuser/blob/main/mcp/README.md" target="_blank" rel="noopener">Docs</a>
      <a href="/demo">Demo</a>
    </div>
  </div>
</footer>

<script>
  const cta = document.getElementById('install-cta');
  const label = document.getElementById('copy-label');
  const cmd = 'claude mcp add dearuser -- npx dearuser-mcp';
  cta?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(cmd);
      if (label) {
        label.textContent = 'Copied';
        setTimeout(() => { label.textContent = 'Copy'; }, 1800);
      }
    } catch (e) {
      console.warn('clipboard failed', e);
    }
  });
</script>

</body>
</html>
