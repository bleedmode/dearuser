---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Dear User — Your AI collaboration partner" active="home">

<style>
  /* Hero ----------------------------------------------------------- */
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 88px 24px 96px;
    position: relative;
  }
  .hero-eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-action-600);
    margin-bottom: 24px;
  }
  .hero h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(40px, 7vw, 76px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--c-ink-900);
    margin: 0;
    max-width: 820px;
  }
  .hero h1 .accent { color: var(--c-action-600); }
  .hero-sub {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(17px, 1.7vw, 19px);
    color: var(--c-ink-700);
    line-height: 1.55;
    max-width: 560px;
    margin: 28px 0 36px;
  }
  .hero-sub p { margin: 0 0 12px; }
  .hero-sub p:last-child { margin-bottom: 0; }

  /* Hero actions — primary install + secondary example link */
  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .hero-example-link {
    color: var(--c-ink-500);
    text-decoration: none;
    font-size: 14px;
    border-bottom: 1px solid var(--c-paper-200);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .hero-example-link:hover {
    color: var(--c-ink-900);
    border-color: var(--c-ink-500);
  }

  /* Install block --------------------------------------------------- */
  .install {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 10px;
    padding: 14px 18px;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 14px;
    cursor: pointer;
    color: var(--c-ink-900);
    transition: border-color 0.15s, background 0.15s;
    user-select: none;
  }
  .install:hover { border-color: var(--c-accent-500); background: var(--c-paper-50); }
  .install .prompt { color: var(--c-ink-400); }
  .install .cmd { color: var(--c-ink-900); }
  .install .copy {
    margin-left: 6px;
    font-family: 'Geist', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-ink-500);
    padding: 3px 8px;
    border-radius: 4px;
    background: var(--c-paper-200);
    transition: background 0.15s, color 0.15s;
  }
  .install:hover .copy { background: var(--c-action-100); color: var(--c-action-700); }

  .hero-secondary {
    margin-top: 20px;
    font-size: 14px;
    color: var(--c-ink-500);
  }
  .hero-secondary a {
    color: var(--c-ink-700);
    text-decoration: none;
    border-bottom: 1px solid var(--c-paper-300);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }
  .hero-secondary a:hover { color: var(--c-action-600); border-color: var(--c-action-600); }

  /* Features grid --------------------------------------------------- */
  .features-section {
    padding: 64px 0 40px;
    border-top: 1px solid var(--c-paper-200);
  }
  .section-head {
    max-width: 720px;
    margin: 0 auto 40px;
    padding: 0 24px;
  }
  .section-eyebrow {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ink-400);
    margin-bottom: 12px;
  }
  .section-title {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--c-ink-900);
    margin: 0;
  }
  .section-sub {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 18px;
    color: var(--c-ink-700);
    line-height: 1.55;
    margin: 12px 0 0;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (max-width: 760px) {
    .features-grid { grid-template-columns: 1fr; }
  }
  .feature {
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 14px;
    padding: 28px;
    transition: border-color 0.15s, transform 0.15s;
  }
  .feature:hover {
    border-color: var(--c-accent-500);
    transform: translateY(-2px);
  }
  .feature-badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 9px;
    border-radius: 5px;
    margin-bottom: 18px;
    background: var(--c-action-100);
    color: var(--c-action-700);
  }
  .feature h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 10px;
    color: var(--c-ink-900);
  }
  .feature p {
    margin: 0 0 18px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--c-ink-700);
  }
  .feature-cmd {
    display: inline-block;
    font-family: 'Geist Mono', monospace;
    font-size: 12.5px;
    background: var(--c-paper-50);
    border: 1px solid var(--c-paper-200);
    color: var(--c-ink-700);
    padding: 7px 11px;
    border-radius: 6px;
  }
  .feature-cmd .fn { color: var(--c-ink-900); }

  /* How it works ---------------------------------------------------- */
  .how {
    padding: 72px 0;
    border-top: 1px solid var(--c-paper-200);
  }
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
  }
  @media (max-width: 760px) { .steps { grid-template-columns: 1fr; } }
  .step {
    padding: 24px;
    border: 1px solid var(--c-paper-200);
    border-radius: 12px;
    background: var(--c-paper-100);
  }
  .step-num {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.15em;
    color: var(--c-action-600);
    margin-bottom: 14px;
  }
  .step h4 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 22px;
    margin: 0 0 8px;
    letter-spacing: -0.01em;
    color: var(--c-ink-900);
  }
  .step p {
    margin: 0 0 14px;
    font-size: 14px;
    color: var(--c-ink-700);
    line-height: 1.55;
  }
  .step code {
    display: block;
    font-family: 'Geist Mono', monospace;
    font-size: 12.5px;
    background: var(--c-paper-50);
    border: 1px solid var(--c-paper-200);
    color: var(--c-ink-900);
    padding: 10px 12px;
    border-radius: 6px;
    word-break: break-all;
  }

  /* Principles ------------------------------------------------------ */
  .principles {
    padding: 72px 0;
    border-top: 1px solid var(--c-paper-200);
    text-align: center;
  }
  .principle-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    max-width: 880px;
    margin: 32px auto 0;
    padding: 0 24px;
  }
  @media (max-width: 760px) { .principle-grid { grid-template-columns: 1fr; text-align: left; } }
  .principle h5 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 18px;
    margin: 0 0 8px;
    color: var(--c-ink-900);
  }
  .principle p {
    margin: 0;
    font-size: 14px;
    color: var(--c-ink-500);
    line-height: 1.55;
  }

  /* Quote from the letter ------------------------------------------ */
  .pullquote {
    padding: 72px 0;
    border-top: 1px solid var(--c-paper-200);
    text-align: center;
  }
  .pullquote blockquote {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 3.5vw, 36px);
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--c-ink-900);
    max-width: 720px;
    margin: 0 auto;
    padding: 0 32px;
    border-left: 3px solid var(--c-action-600);
  }
  .pullquote cite {
    display: block;
    margin-top: 18px;
    font-style: normal;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-ink-400);
  }
</style>

<!-- Hero ------------------------------------------------------------- -->
<section class="hero">
  <div class="hero-eyebrow">
    <span class="lang-da">Din AI-samarbejdspartner</span>
    <span class="lang-en">Your AI collaboration partner</span>
  </div>
  <h1>
    <span class="lang-da">Kære bruger,<br/>hvordan går samarbejdet med din <span class="accent">agent?</span></span>
    <span class="lang-en">Dear User,<br/>how's the collaboration with your <span class="accent">agent?</span></span>
  </h1>

  <div class="hero-sub">
    <p>
      <span class="lang-da">I år vil du bruge flere timer med din AI-agent end med de fleste mennesker i dit liv. Dear User er bygget til at få det bedste ud af de timer.</span>
      <span class="lang-en">This year, you'll spend more hours with your AI agent than with most people in your life. Dear User was built to make the most of those hours.</span>
    </p>
  </div>

  <div class="hero-actions">
    <div class="install" id="install-cta" title="Click to copy">
      <span class="prompt">$</span>
      <span class="cmd">claude mcp add dearuser -- npx dearuser-mcp</span>
      <span class="copy" id="copy-label">
        <span class="lang-da">Kopiér</span><span class="lang-en">Copy</span>
      </span>
    </div>
    <a href="/example" class="hero-example-link">
      <span class="lang-da">Eller se et eksempel →</span>
      <span class="lang-en">Or see an example →</span>
    </a>
  </div>
</section>

<script is:inline>
  var cta = document.getElementById('install-cta');
  var label = document.getElementById('copy-label');
  var cmd = 'claude mcp add dearuser -- npx dearuser-mcp';
  if (cta) {
    cta.addEventListener('click', function () {
      if (!navigator.clipboard) return;
      navigator.clipboard.writeText(cmd).then(function () {
        if (!label) return;
        var html = label.innerHTML;
        label.innerHTML = '<span class="lang-da">Kopieret</span><span class="lang-en">Copied</span>';
        setTimeout(function () { label.innerHTML = html; }, 1600);
      }).catch(function () {});
    });
  }
</script>

<!-- Features --------------------------------------------------------- -->
<section class="features-section" id="features">
  <div class="section-head">
    <div class="section-eyebrow">
      <span class="lang-da">Seks værktøjer</span><span class="lang-en">Six tools</span>
    </div>
    <h2 class="section-title">
      <span class="lang-da">Hver ét spørgsmål. Hvert et svar som et brev.</span>
      <span class="lang-en">One question each. Each answer a letter.</span>
    </h2>
    <p class="section-sub">
      <span class="lang-da">Dear User scanner din <em>CLAUDE.md</em>, memory, hooks, skills og sessioner — og orkestrerer sikkerheds­tjekkene der allerede kigger på din stack. Så skriver den et brev til dig. Alle værktøjer kører lokalt via MCP. Kald dem fra Claude Code — eller fra det lille lokale dashboard der følger med. Ingen dashboards uden stemme. Ingen råd uden konkret kode.</span>
      <span class="lang-en">Dear User reads your <em>CLAUDE.md</em>, memory, hooks, skills and sessions — and orchestrates the security advisors already watching your stack. Then it writes you a letter. All tools run locally over MCP. Call them from Claude Code — or from the small local dashboard that ships with it. No dashboards without a voice. No advice without concrete code.</span>
    </p>
  </div>

  <div class="features-grid">
    <div class="feature">
      <span class="feature-badge">
        <span class="lang-da">Samarbejde</span><span class="lang-en">Collab</span>
      </span>
      <h3>
        <span class="lang-da">Læser jeres samarbejde.</span>
        <span class="lang-en">Reads how you two work.</span>
      </h3>
      <p>
        <span class="lang-da">Scanner CLAUDE.md, memory, hooks, skills, sessioner og lokal git-aktivitet. Returnerer en persona, en samarbejds-score, friktionsmønstre og proaktive anbefalinger baseret på hvad I faktisk gør — for eksempel <em>"wrap det CLI-værktøj du kalder fra mange skills som en MCP server"</em>.</span>
        <span class="lang-en">Reads your CLAUDE.md, memory, hooks, skills, sessions and local git activity. Returns a persona, a collaboration score, friction patterns and proactive recommendations based on what you actually do — for example <em>"wrap the CLI you call from many skills as an MCP server"</em>.</span>
      </p>
      <span class="feature-cmd"><span class="fn">mcp__dearuser__collab</span></span>
    </div>

    <div class="feature">
      <span class="feature-badge health">
        <span class="lang-da">System-sundhed</span><span class="lang-en">Health</span>
      </span>
      <h3>
        <span class="lang-da">Finder inkoherensen.</span>
        <span class="lang-en">Finds the incoherence.</span>
      </h3>
      <p>
        <span class="lang-da">Bygger en graf af din stack — skills, scheduled tasks, hooks, memory — og finder orphan-jobs (output ingen læser), overlappende artefakter, manglende lukning og markdown-filer brugt som databaser. Det tjek, din opsætning har brug for <em>før</em> den bryder stille ned.</span>
        <span class="lang-en">Builds a graph of your stack — skills, scheduled tasks, hooks, memory — and surfaces orphan jobs (produce output nothing reads), overlapping artifacts, missing closure and markdown files used as databases. The audit your setup needs <em>before</em> it breaks silently.</span>
      </p>
      <span class="feature-cmd"><span class="fn">mcp__dearuser__health</span></span>
    </div>

    <div class="feature">
      <span class="feature-badge security">
        <span class="lang-da">Sikkerhed</span><span class="lang-en">Security</span>
      </span>
      <h3>
        <span class="lang-da">Én rude. Alle platforme.</span>
        <span class="lang-en">One pane. Every platform.</span>
      </h3>
      <p>
        <span class="lang-da">Orkestrerer sikkerheds-advisors du allerede har men aldrig tjekker samlet. Supabase RLS-lints. GitHub Dependabot og secret-scanning. <em>npm audit</em>. Vercel env vars. Plus det agent-setup-scan kun Dear User kan: lækkede nøgler i CLAUDE.md, prompt-injection-overflader i hooks, regel-konflikter hvor CLAUDE.md siger <em>"never force-push"</em> men en hook gør det alligevel.</span>
        <span class="lang-en">Orchestrates the security advisors you already have but never check in one place. Supabase RLS lints. GitHub Dependabot and secret scanning. <em>npm audit</em>. Vercel env vars. Plus the agent-setup scan only Dear User can do: leaked keys in CLAUDE.md, prompt-injection surfaces in hooks, rule conflicts where CLAUDE.md says <em>"never force-push"</em> but a hook does it anyway.</span>
      </p>
      <span class="feature-cmd"><span class="fn">mcp__dearuser__security</span></span>
    </div>

    <div class="feature">
      <span class="feature-badge onboard">
        <span class="lang-da">Opstart</span><span class="lang-en">Onboard</span>
      </span>
      <h3>
        <span class="lang-da">Sat op, guidet.</span>
        <span class="lang-en">Set up, guided.</span>
      </h3>
      <p>
        <span class="lang-da">En samtale i syv trin der lærer dig at kende, forklarer grundbegreberne (kode, chat, schedule, OS — de fire substrates) og producerer en plan: en CLAUDE.md-starter, skill-valg, hook-valg og dine næste tre konkrete skridt. Lavet både til ikke-tekniske professionelle og tekniske power-users.</span>
        <span class="lang-en">A seven-step conversation that learns about you, teaches the core concepts (code, chat, schedule, OS — the four substrates) and produces a plan: a CLAUDE.md starter, skill picks, hook picks and your next three concrete steps. Built for non-technical professionals and technical power-users alike.</span>
      </p>
      <span class="feature-cmd"><span class="fn">mcp__dearuser__onboard</span></span>
    </div>

    <div class="feature">
      <span class="feature-badge wrapped">
        <span class="lang-da">I tal</span><span class="lang-en">Wrapped</span>
      </span>
      <h3>
        <span class="lang-da">Det sjove tal.</span>
        <span class="lang-en">See what's fun.</span>
      </h3>
      <p>
        <span class="lang-da">Spotify Wrapped-agtige stats om hvordan du og din agent faktisk arbejder sammen. Dine rettelser, dit <em>"Don't"</em>-regel-forhold, din agents arketype, systemet du har bygget. Kan deles. Kan screenshottes.</span>
        <span class="lang-en">Spotify Wrapped-style stats about how you and your agent actually work together. Your corrections, your <em>"Don't"</em>-rules ratio, your agent archetype, the system you've built. Shareable. Screenshotable.</span>
      </p>
      <span class="feature-cmd"><span class="fn">mcp__dearuser__wrapped</span></span>
    </div>

    <div class="feature">
      <span class="feature-badge history">
        <span class="lang-da">Historik</span><span class="lang-en">History</span>
      </span>
      <h3>
        <span class="lang-da">Hvad har ændret sig?</span>
        <span class="lang-en">What changed?</span>
      </h3>
      <p>
        <span class="lang-da">Viser seneste rapporter, score-trend over tid, eller hvad der blev bedre og værre siden sidste scan. Ingen re-scan nødvendig — bare et hurtigt overblik over samarbejdets retning.</span>
        <span class="lang-en">Shows recent reports, score trend over time, or what improved and regressed since the last scan. No re-scan needed — just a quick look at where the collaboration is going.</span>
      </p>
      <span class="feature-cmd"><span class="fn">mcp__dearuser__history</span></span>
    </div>
  </div>
</section>

<!-- Pull quote from an example letter -------------------------------- -->
<section class="pullquote">
  <blockquote>
    <span class="lang-da">"Jeg har bemærket at du retter din agent på den samme måde 3-4 gange om ugen — men det står ikke i CLAUDE.md endnu. Skal vi gemme det som en regel, så du slipper for at sige det igen?"</span>
    <span class="lang-en">"I've noticed you correct your agent the same way three or four times a week — but it's not in CLAUDE.md yet. Should we save it as a rule, so you don't have to say it again?"</span>
  </blockquote>
  <cite>
    <span class="lang-da">Uddrag fra en collab-rapport</span>
    <span class="lang-en">From a collab letter</span>
  </cite>
</section>

<!-- Install / How it works ------------------------------------------ -->
<section class="how" id="install">
  <div class="section-head" style="text-align:center;">
    <div class="section-eyebrow">
      <span class="lang-da">Kom i gang</span><span class="lang-en">Get started</span>
    </div>
    <h2 class="section-title">
      <span class="lang-da">Tre skridt.</span><span class="lang-en">Three steps.</span>
    </h2>
  </div>
  <div class="steps">
    <div class="step">
      <div class="step-num">01 — <span class="lang-da">Installér</span><span class="lang-en">Install</span></div>
      <h4><span class="lang-da">Tilføj MCP-serveren</span><span class="lang-en">Add the MCP server</span></h4>
      <p>
        <span class="lang-da">Registrér Dear User i Claude Code. Ingen konti, ingen cloud.</span>
        <span class="lang-en">Register Dear User in Claude Code. No accounts, no cloud.</span>
      </p>
      <code>claude mcp add dearuser -- npx dearuser-mcp</code>
    </div>
    <div class="step">
      <div class="step-num">02 — <span class="lang-da">Skriv første brev</span><span class="lang-en">Write first letter</span></div>
      <h4><span class="lang-da">Bed din agent</span><span class="lang-en">Ask your agent</span></h4>
      <p>
        <span class="lang-da">I en hvilken som helst Claude Code-session:</span>
        <span class="lang-en">In any Claude Code session:</span>
      </p>
      <code>
        <span class="lang-da">Kør dearuser collab</span>
        <span class="lang-en">Run dearuser collab</span>
      </code>
    </div>
    <div class="step">
      <div class="step-num">03 — <span class="lang-da">Læs &amp; del</span><span class="lang-en">Read &amp; share</span></div>
      <h4><span class="lang-da">Åbn dashboardet</span><span class="lang-en">Open the dashboard</span></h4>
      <p>
        <span class="lang-da">Rapporter åbnes lokalt på <code style="background:none;padding:0;border:0;font-family:'Geist Mono',monospace;color:var(--c-action-600);">localhost:7700</code>. Del en screenshot — eller generer et Wrapped.</span>
        <span class="lang-en">Reports open locally at <code style="background:none;padding:0;border:0;font-family:'Geist Mono',monospace;color:var(--c-action-600);">localhost:7700</code>. Share a screenshot — or generate a Wrapped.</span>
      </p>
      <code>
        <span class="lang-da">Kør dearuser wrapped</span>
        <span class="lang-en">Run dearuser wrapped</span>
      </code>
    </div>
  </div>
</section>

<!-- Principles ------------------------------------------------------ -->
<section class="principles">
  <div class="section-head" style="margin-bottom:8px;">
    <div class="section-eyebrow" style="text-align:center;">
      <span class="lang-da">Sådan virker det</span><span class="lang-en">How it works</span>
    </div>
    <h2 class="section-title" style="text-align:center;">
      <span class="lang-da">Tre kilder. Ét brev.</span>
      <span class="lang-en">Three sources. One letter.</span>
    </h2>
  </div>
  <div class="principle-grid">
    <div class="principle">
      <h5>
        <span class="lang-da">Lokalt som standard</span><span class="lang-en">Local by default</span>
      </h5>
      <p>
        <span class="lang-da">Alt kører på din maskine. Intet data forlader din opsætning. SQLite-database i <code style="font-family:'Geist Mono',monospace;">~/.dearuser/</code>.</span>
        <span class="lang-en">Everything runs on your machine. No data leaves your setup. SQLite database in <code style="font-family:'Geist Mono',monospace;">~/.dearuser/</code>.</span>
      </p>
    </div>
    <div class="principle">
      <h5>
        <span class="lang-da">Tre videnskilder</span><span class="lang-en">Three knowledge sources</span>
      </h5>
      <p>
        <span class="lang-da">Dine filer, en ekstern kuratet vidensbase, og et feedback-loop der tracker hvad der faktisk virkede efter en anbefaling.</span>
