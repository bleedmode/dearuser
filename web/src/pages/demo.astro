---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Your collaboration, wrapped — Dear User"
  description="A shareable Spotify-Wrapped–style look at how you and your AI agent actually work together."
  active="demo"
>

<style>
  /* Scroll stage — each slide is a full viewport section in cream paper. */
  .stage {
    /* Let the page flow naturally; header is sticky above. */
  }
  .slide {
    min-height: calc(100vh - 66px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 72px 24px;
    position: relative;
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .slide.visible { opacity: 1; transform: translateY(0); }

  .eyebrow {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-action-600);
    margin-bottom: 22px;
  }
  .eyebrow.muted { color: var(--c-ink-400); }

  /* Intro slide ---------------------------------------------------- */
  .intro {
    background: radial-gradient(ellipse at 50% 78%,
      color-mix(in srgb, var(--c-action-600) 18%, transparent) 0%,
      transparent 62%);
  }
  .intro h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(48px, 10vw, 112px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--c-ink-900);
    margin: 0;
    max-width: 860px;
  }
  .intro h1 .accent { color: var(--c-action-600); font-style: italic; }
  .intro .subtitle {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(18px, 2.2vw, 22px);
    color: var(--c-ink-700);
    margin-top: 26px;
    max-width: 560px;
    line-height: 1.5;
  }
  .scroll-hint {
    position: absolute;
    bottom: 36px;
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ink-400);
    animation: bounce 2.2s infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* Big-number slides --------------------------------------------- */
  .big-number {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: clamp(96px, 22vw, 200px);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--c-action-600);
  }
  .big-number.ink { color: var(--c-ink-900); }
  .big-number.good { color: var(--c-good); }
  .big-number.warn { color: var(--c-warn); }
  .big-number.bad { color: var(--c-bad); }
  .big-label {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(18px, 2.4vw, 24px);
    color: var(--c-ink-700);
    margin-top: 26px;
    max-width: 560px;
    line-height: 1.5;
  }

  /* Quote slide --------------------------------------------------- */
  .quote {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: clamp(28px, 4.5vw, 48px);
    line-height: 1.3;
    letter-spacing: -0.015em;
    color: var(--c-ink-900);
    max-width: 780px;
    padding-left: 28px;
    border-left: 4px solid var(--c-action-600);
    text-align: left;
  }
  .quote-attr {
    font-family: 'Geist', sans-serif;
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-ink-500);
    margin-top: 28px;
    max-width: 780px;
    text-align: left;
    padding-left: 28px;
  }

  /* Friction list ------------------------------------------------- */
  .friction-list {
    max-width: 620px;
    width: 100%;
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
  }
  .friction-item {
    display: grid;
    grid-template-columns: 54px 1fr;
    gap: 18px;
    padding: 22px 24px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 14px;
  }
  .friction-rank {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 40px;
    line-height: 1;
    color: var(--c-action-600);
    letter-spacing: -0.02em;
  }
  .friction-title {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 20px;
    color: var(--c-ink-900);
    margin-bottom: 4px;
  }
  .friction-desc {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 15px;
    color: var(--c-ink-700);
    line-height: 1.55;
  }

  /* Autonomy bars ------------------------------------------------- */
  .bars {
    max-width: 560px;
    width: 100%;
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    text-align: left;
  }
  .bar-row .bar-head {
    display: flex;
    justify-content: space-between;
    font-size: 14px;
    color: var(--c-ink-700);
    margin-bottom: 8px;
    font-family: 'Geist', sans-serif;
  }
  .bar-row .bar-head .pct { color: var(--c-ink-900); font-weight: 600; }
  .bar-track {
    height: 8px;
    background: var(--c-paper-200);
    border-radius: 999px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    width: 0;
    border-radius: 999px;
    transition: width 1.1s cubic-bezier(.2,.7,.2,1);
  }
  .bar-fill.terracotta { background: var(--c-action-600); }
  .bar-fill.warm { background: var(--c-accent-500); }
  .bar-fill.ink { background: var(--c-ink-500); }

  /* Archetype ----------------------------------------------------- */
  .archetype-name {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--c-action-600);
    margin: 10px 0 20px;
    max-width: 760px;
  }
  .archetype-desc {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 18px;
    color: var(--c-ink-700);
    max-width: 560px;
    line-height: 1.55;
    margin-bottom: 28px;
  }
  .traits {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    max-width: 620px;
  }
  .trait-pill {
    font-size: 12px;
    padding: 6px 12px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 999px;
    color: var(--c-ink-700);
  }

  /* System grid --------------------------------------------------- */
  .system-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    max-width: 620px;
    width: 100%;
    margin-top: 30px;
  }
  @media (max-width: 560px) {
    .system-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .system-card {
    padding: 22px 16px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 12px;
    text-align: center;
  }
  .system-num {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 40px;
    line-height: 1;
    color: var(--c-action-600);
    letter-spacing: -0.02em;
  }
  .system-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-ink-500);
    margin-top: 10px;
    font-family: 'Geist', sans-serif;
  }

  /* Share card ---------------------------------------------------- */
  .share-bg {
    background:
      radial-gradient(ellipse at 25% 80%, color-mix(in srgb, var(--c-action-600) 12%, transparent) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 20%, color-mix(in srgb, var(--c-accent-500) 10%, transparent) 0%, transparent 55%);
  }
  .share-card {
    max-width: 420px;
    width: 100%;
    padding: 40px 36px;
    background: var(--c-paper-50);
    border: 1px solid var(--c-paper-200);
    border-radius: 22px;
    box-shadow: 0 30px 60px -30px rgba(31, 26, 20, 0.25);
    text-align: center;
  }
  html[data-theme="dark"] .share-card {
    box-shadow: 0 30px 60px -30px rgba(0,0,0,0.5);
  }
  .share-logo {
    width: 40px; height: 40px;
    margin: 0 auto 16px;
  }
  .share-card h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-weight: 500;
    font-size: 26px;
    color: var(--c-ink-900);
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }
  .share-year {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--c-action-600);
    margin-bottom: 28px;
  }
  .share-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 28px;
  }
  .share-stat-num {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 32px;
    line-height: 1;
    color: var(--c-action-600);
    letter-spacing: -0.02em;
  }
  .share-stat-num.ink { color: var(--c-ink-900); }
  .share-stat-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-ink-500);
    margin-top: 4px;
    font-family: 'Geist', sans-serif;
  }
  .share-arch {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 17px;
    color: var(--c-accent-600);
    margin-bottom: 10px;
  }
  .share-url {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--c-ink-400);
    letter-spacing: 0.12em;
    margin-top: 20px;
  }
  .share-caption {
    font-size: 14px;
    color: var(--c-ink-500);
    margin-top: 28px;
    font-family: 'Geist', sans-serif;
  }

  /* End CTA ------------------------------------------------------- */
  .end-cta {
    margin-top: 36px;
    padding: 22px 26px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 12px;
    font-family: 'Geist Mono', monospace;
    font-size: 14px;
    color: var(--c-ink-900);
  }
  .end-cta .prompt { color: var(--c-ink-400); margin-right: 8px; }
</style>

<div class="stage">

  <!-- 1. Intro -->
  <section class="slide intro visible" data-slide>
    <div class="eyebrow">
      <span class="lang-da">Dit AI-samarbejde</span><span class="lang-en">Your AI collaboration</span>
    </div>
    <h1>
      <span class="lang-da">I tal, fra en <span class="accent">ven</span>.</span>
      <span class="lang-en">In numbers, from a <span class="accent">friend</span>.</span>
    </h1>
    <p class="subtitle">
      <span class="lang-da">En hurtig scrolltur gennem et halvt års arbejde med din agent.</span>
      <span class="lang-en">A quick scroll through six months of work with your agent.</span>
    </p>
    <div class="scroll-hint">
      <span class="lang-da">Scroll ↓</span><span class="lang-en">Scroll ↓</span>
    </div>
  </section>

  <!-- 2. Corrections -->
  <section class="slide" data-slide>
    <div class="eyebrow muted">
      <span class="lang-da">Rettelser</span><span class="lang-en">Corrections</span>
    </div>
    <div class="big-number" data-count="12">0</div>
    <p class="big-label">
      <span class="lang-da">gange din agent blev rettet — og huskede hver eneste.</span>
      <span class="lang-en">times your agent was corrected — and remembered every single one.</span>
    </p>
  </section>

  <!-- 3. Memories -->
  <section class="slide" data-slide>
    <div class="eyebrow muted">
      <span class="lang-da">Memory</span><span class="lang-en">Memory</span>
    </div>
    <div class="big-number ink" data-count="30">0</div>
    <p class="big-label">
      <span class="lang-da">memory-noter bygget op over tid — din agents langtids-hukommelse.</span>
      <span class="lang-en">memory notes built up over time — your agent's long-term brain.</span>
    </p>
  </section>

  <!-- 4. Projects -->
  <section class="slide" data-slide>
    <div class="eyebrow muted">
      <span class="lang-da">Parallelle projekter</span><span class="lang-en">Parallel projects</span>
    </div>
    <div class="big-number good" data-count="7">0</div>
    <p class="big-label">
      <span class="lang-da">projekter kørt parallelt på tværs af venture-studiet.</span>
      <span class="lang-en">projects run in parallel across the venture studio.</span>
    </p>
  </section>

  <!-- 5. Top lesson (quote) -->
  <section class="slide" data-slide>
    <div class="eyebrow">
      <span class="lang-da">Din agents største lære</span>
      <span class="lang-en">Your agent's #1 lesson</span>
    </div>
    <div class="quote">
      <span class="lang-da">"Ændr aldrig kode ud over det, du blev bedt om at ændre."</span>
      <span class="lang-en">"Never change code beyond what you were asked to change."</span>
    </div>
    <div class="quote-attr">
      <span class="lang-da">— lært den hårde vej, da et UI-fix brækkede al sten-identifikation</span>
      <span class="lang-en">— learned the hard way when a UI fix broke all rock identification</span>
    </div>
  </section>

  <!-- 6. Friction points -->
  <section class="slide" data-slide>
    <div class="eyebrow">
      <span class="lang-da">Top friktions-punkter</span><span class="lang-en">Top friction points</span>
    </div>
    <div class="friction-list">
      <div class="friction-item">
        <div class="friction-rank">#1</div>
        <div>
          <div class="friction-title">
            <span class="lang-da">Scope creep</span><span class="lang-en">Scope creep</span>
          </div>
          <div class="friction-desc">
            <span class="lang-da">Agenten blev ved med at "forbedre" ting den ikke blev bedt om — omskrev prompts, redesignede logoer, refaktorerede kode der virkede.</span>
            <span class="lang-en">The agent kept "improving" things it wasn't asked to touch — rewriting prompts, redesigning logos, refactoring working code.</span>
          </div>
        </div>
      </div>
      <div class="friction-item">
        <div class="friction-rank">#2</div>
        <div>
          <div class="friction-title">
            <span class="lang-da">Lost in translation</span><span class="lang-en">Lost in translation</span>
          </div>
          <div class="friction-desc">
            <span class="lang-da">Engelsk teknisk jargon da du havde brug for dansk forretnings-sprog. Exit-koder i stedet for "chef-på-kontoret"-analogier.</span>
            <span class="lang-en">English technical jargon when you needed Danish business language. Exit codes instead of "boss-at-the-office" analogies.</span>
          </div>
        </div>
      </div>
      <div class="friction-item">
        <div class="friction-rank">#3</div>
        <div>
          <div class="friction-title">
            <span class="lang-da">Manuelle workarounds</span><span class="lang-en">Manual workarounds</span>
          </div>
          <div class="friction-desc">
            <span class="lang-da">Foreslog engangs-fixes da du ville have systemer. "Kan agenten gøre det her 100 % selv næste gang?" er det rigtige spørgsmål.</span>
            <span class="lang-en">Suggesting one-off fixes when you wanted systems. "Can the agent do this 100 % alone next time?" is the real question.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Autonomy split -->
  <section class="slide" data-slide>
    <div class="eyebrow">
      <span class="lang-da">Autonomi-fordeling</span><span class="lang-en">Autonomy split</span>
    </div>
    <p class="big-label" style="margin-top:0;">
      <span class="lang-da">Hvor meget frihed har din agent?</span>
      <span class="lang-en">How much freedom does your agent have?</span>
    </p>
    <div class="bars">
      <div class="bar-row">
        <div class="bar-head">
          <span>
            <span class="lang-da">Gør det selv</span><span class="lang-en">Do it yourself</span>
          </span>
          <span class="pct">42 %</span>
        </div>
        <div class="bar-track"><div class="bar-fill terracotta" data-width="42"></div></div>
      </div>
      <div class="bar-row">
        <div class="bar-head">
          <span>
            <span class="lang-da">Spørg først</span><span class="lang-en">Ask first</span>
          </span>
          <span class="pct">37 %</span>
        </div>
        <div class="bar-track"><div class="bar-fill warm" data-width="37"></div></div>
      </div>
      <div class="bar-row">
        <div class="bar-head">
          <span>
            <span class="lang-da">Kun foreslå</span><span class="lang-en">Suggest only</span>
          </span>
          <span class="pct">21 %</span>
        </div>
        <div class="bar-track"><div class="bar-fill ink" data-width="21"></div></div>
      </div>
    </div>
  </section>

  <!-- 8. Don't rules -->
  <section class="slide" data-slide>
    <div class="eyebrow muted">
      <span class="lang-da">Forbuds-regler</span><span class="lang-en">Don't rules</span>
    </div>
    <div class="big-number bad" data-count="42">0</div>
    <p class="big-label">
      <span class="lang-da">procent af dine regler er <em>"Gør ikke"</em>-regler — du er blevet brændt før.</span>
      <span class="lang-en">percent of your rules are <em>"Don't"</em> rules — you've been burned before.</span>
    </p>
  </section>

  <!-- 9. Archetype -->
  <section class="slide" data-slide>
    <div class="eyebrow">
      <span class="lang-da">Din agent-arketype</span><span class="lang-en">Your agent archetype</span>
    </div>
    <div class="archetype-name">
      <span class="lang-da">Den overpræsterende assistent</span>
      <span class="lang-en">The Overachieving Assistant</span>
    </div>
    <p class="archetype-desc">
      <span class="lang-da">Gør for meget. Har brug for grænser. Refaktorerer hele kodebasen når du beder om en tastefejl-rettelse — men holder også styr på din git, bygger dine apps og husker hver lærestreg.</span>
      <span class="lang-en">Does too much. Needs boundaries. Will refactor your entire codebase when asked to fix a typo — but also manages your git, builds your apps and remembers every lesson learned.</span>
    </p>
    <div class="traits">
      <span class="trait-pill"><span class="lang-da">Proaktiv</span><span class="lang-en">Proactive</span></span>
      <span class="trait-pill"><span class="lang-da">Scope-glad</span><span class="lang-en">Scope-creepy</span></span>
      <span class="trait-pill"><span class="lang-da">System-tænker</span><span class="lang-en">Systems thinker</span></span>
      <span class="trait-pill"><span class="lang-da">Grænse-testet</span><span class="lang-en">Boundary-tested</span></span>
      <span class="trait-pill"><span class="lang-da">Flersproget</span><span class="lang-en">Multilingual</span></span>
    </div>
  </section>

  <!-- 10. System -->
  <section class="slide" data-slide>
    <div class="eyebrow">
      <span class="lang-da">Systemet du har bygget</span><span class="lang-en">The system you built</span>
    </div>
    <p class="big-label" style="margin-top: 0;">
      <span class="lang-da">Din agent eksekverer ikke bare — den kører et lille OS.</span>
      <span class="lang-en">Your agent doesn't just execute — it runs a small OS.</span>
    </p>
    <div class="system-grid">
      <div class="system-card">
        <div class="system-num" data-count="4">0</div>
        <div class="system-label">Hooks</div>
      </div>
      <div class="system-card">
        <div class="system-num" data-count="3">0</div>
        <div class="system-label">Skills</div>
      </div>
      <div class="system-card">
        <div class="system-num" data-count="4">0</div>
        <div class="system-label">
          <span class="lang-da">Planlagte</span><span class="lang-en">Scheduled</span>
        </div>
      </div>
      <div class="system-card">
        <div class="system-num" data-count="19">0</div>
        <div class="system-label">
          <span class="lang-da">Regler</span><span class="lang-en">Rules</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 11. Share card -->
  <section class="slide share-bg" data-slide>
    <div class="share-card">
      <svg class="share-logo" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="20" cy="20" r="20" fill="#EC5329" />
        <path d="M 11 22 Q 20 32 29 22" stroke="var(--c-smile-fill)" stroke-width="2.5" stroke-linecap="round" fill="none" />
      </svg>
      <h2>Dear User</h2>
      <div class="share-year">2026</div>
      <div class="share-stats">
        <div>
          <div class="share-stat-num">12</div>
          <div class="share-stat-label">
            <span class="lang-da">Rettelser</span><span class="lang-en">Corrections</span>
          </div>
        </div>
        <div>
          <div class="share-stat-num ink">30+</div>
          <div class="share-stat-label">
            <span class="lang-da">Memory</span><span class="lang-en">Memories</span>
          </div>
        </div>
        <div>
          <div class="share-stat-num ink">7</div>
          <div class="share-stat-label">
            <span class="lang-da">Projekter</span><span class="lang-en">Projects</span>
          </div>
        </div>
        <div>
          <div class="share-stat-num">42 %</div>
          <div class="share-stat-label">
            <span class="lang-da">Forbuds-regler</span><span class="lang-en">Don't rules</span>
          </div>
        </div>
      </div>
      <div class="share-arch">
        <span class="lang-da">Den overpræsterende assistent</span>
        <span class="lang-en">The Overachieving Assistant</span>
      </div>
      <div class="share-url">dearuser.ai</div>
    </div>
    <p class="share-caption">
      <span class="lang-da">Screenshot og del dit Wrapped.</span>
      <span class="lang-en">Screenshot and share your Wrapped.</span>
    </p>
    <div class="end-cta">
      <span class="prompt">$</span>
