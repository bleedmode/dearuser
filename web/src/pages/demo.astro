---
// demo.astro — public sample of the Wrapped scroll-through, rendered with
// the shared slides renderer so this page stays in sync with the share
// page (/r/<token>) and the dashboard (/wrapped) without any drift.
//
// The slide content lives in ../lib/wrapped-slides.ts; sample data in
// ../lib/wrapped-slides-sample.ts. This file is the thin shell.

import Layout from '../layouts/Layout.astro';
import { renderWrappedSlides } from '../lib/wrapped-slides.ts';
import { DEMO_WRAPPED } from '../lib/wrapped-slides-sample.ts';

const html = renderWrappedSlides(DEMO_WRAPPED);
---
<Layout
  title="Your collaboration, wrapped — Dear User"
  description="A shareable Spotify-Wrapped–style look at how you and your AI agent actually work together."
  active="demo"
>
  <Fragment set:html={html} />
</Layout>
