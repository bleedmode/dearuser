---
// ShareLayout — wraps a public share page with a minimal header/footer.
//
// Differs from Layout.astro:
//   - No site nav (visitors don't need the marketing site's menu — they
//     landed here from a shared link, and the CTA is at the bottom).
//   - Locks data-lang to English by default (shared links cross language
//     boundaries; English reads better for the viral use case).
//   - Richer OG meta so Slack/Twitter/LinkedIn previews show the score.

import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
  noindex?: boolean;
}
const {
  title,
  description = 'A Dear User audit of a Claude Code setup.',
  ogImage,
  ogUrl,
  noindex = false,
} = Astro.props;

const canonical = ogUrl || Astro.url.toString();
---
<!DOCTYPE html>
<html lang="en" data-lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex,nofollow" />}
<link rel="canonical" href={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:type" content="website" />
{ogImage && <meta property="og:image" content={ogImage} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 40 40'%3E%3Ccircle cx='20' cy='20' r='20' fill='%23EC5329'/%3E%3Cpath d='M 11 22 Q 20 32 29 22' stroke='%23FDFBF6' stroke-width='2.5' stroke-linecap='round' fill='none'/%3E%3C/svg%3E" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }

  :root {
    --c-paper-50:   #FDFBF6;
    --c-paper-100:  #F8F2E7;
    --c-paper-200:  #EFE4CF;
    --c-paper-300:  #D8C8A9;
    --c-ink-900:    #1F1A14;
    --c-ink-700:    #3E352A;
    --c-ink-500:    #72655B;
    --c-ink-400:    #A69989;
    --c-accent-600: #C3563B;
    --c-accent-500: #D77356;
    --c-accent-100: #F6E3D7;
    --c-action-700: #C93F1B;
    --c-action-600: #EC5329;
    --c-action-500: #F06B43;
    --c-action-100: #FCE5DB;
    --c-smile-fill: #FDFBF6;
    --c-good:       #059669;
    --c-warn:       #FBBF24;
    --c-bad:        #BE123C;
  }

  html { background: var(--c-paper-50); }
  body {
    font-family: 'Geist', system-ui, -apple-system, sans-serif;
    font-feature-settings: 'ss01';
    background: var(--c-paper-50);
    color: var(--c-ink-900);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }
  a { color: inherit; }

  /* Language toggle — share pages are English-locked (viral/cross-boundary).
     Components render both .lang-da and .lang-en spans; hide Danish here so
     shared links always read in one language. Matches the behavior promised
     in the header comment at the top of this file. */
  html[data-lang="en"] .lang-da { display: none; }
  html[data-lang="da"] .lang-en { display: none; }

  .du-share-header {
    border-bottom: 1px solid var(--c-paper-200);
    padding: 18px 0;
    background: var(--c-paper-50);
  }
  .du-share-header-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .du-share-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--c-ink-900);
  }
  .du-share-logo-mark { width: 26px; height: 26px; flex-shrink: 0; }
  .du-share-logo-name {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 20px;
    letter-spacing: -0.01em;
    font-weight: 500;
  }
  .du-share-cta {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-action-600);
    text-decoration: none;
    border-bottom: 1px solid var(--c-action-100);
    padding-bottom: 2px;
  }
  .du-share-cta:hover {
    border-color: var(--c-action-600);
  }

  .du-share-footer {
    border-top: 1px solid var(--c-paper-200);
    padding: 48px 0 64px;
    margin-top: 72px;
    text-align: center;
  }
  .du-share-footer-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .du-share-footer h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 500;
    font-size: 26px;
    color: var(--c-ink-900);
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }
  .du-share-footer p {
    color: var(--c-ink-700);
    margin: 0 0 20px;
    font-size: 15px;
  }
  .du-share-footer .install-inline {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--c-paper-100);
    border: 1px solid var(--c-paper-200);
    border-radius: 8px;
    padding: 10px 14px;
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
    color: var(--c-ink-900);
  }
  .du-share-footer .install-inline .prompt { color: var(--c-ink-400); }
  .du-share-footer-links {
    margin-top: 24px;
    font-size: 13px;
    color: var(--c-ink-500);
  }
  .du-share-footer-links a {
    color: var(--c-ink-500);
    text-decoration: none;
    border-bottom: 1px solid var(--c-paper-200);
    padding-bottom: 1px;
    margin: 0 10px;
  }
  .du-share-footer-links a:hover { color: var(--c-ink-900); }

  .du-warning-banner {
    background: color-mix(in srgb, var(--c-warn) 18%, var(--c-paper-50));
    border-left: 3px solid var(--c-warn);
    padding: 12px 16px;
    font-size: 13px;
    color: var(--c-ink-700);
    max-width: 720px;
    margin: 16px auto;
    border-radius: 6px;
  }
</style>
</head>
<body>
  <header class="du-share-header">
    <div class="du-share-header-inner">
      <a href="https://dearuser.ai/" class="du-share-logo" aria-label="Dear User home">
        <svg class="du-share-logo-mark" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="20" cy="20" r="20" fill="#EC5329" />
          <path d="M 11 22 Q 20 32 29 22" stroke="var(--c-smile-fill)" stroke-width="2.5" stroke-linecap="round" fill="none" />
        </svg>
        <span class="du-share-logo-name">Dear User</span>
      </a>
      <a href="https://dearuser.ai/" class="du-share-cta">Read your own →</a>
    </div>
  </header>

  <slot />

  <Analytics />

  <script>
    // Website analytics — dearuser.ai only. MCP/dashboard never tracked.
    import { initAnalytics, trackShareViewed } from '../lib/analytics';
    initAnalytics();
    function fire() {
      // Token is the last path segment of /r/<token>. We only pass its
      // length (for anomaly detection) — never the token itself.
      const parts = (window.location.pathname || '').split('/').filter(Boolean);
      const token = parts[0] === 'r' && parts[1] ? parts[1] : null;
      // Report type: read from a non-content signal if the page exposes one.
      // Falls back to "unknown" rather than modifying page markup.
      const kindEl = document.querySelector('[data-report-kind]');
      const reportType = kindEl?.getAttribute('data-report-kind') || 'unknown';
      trackShareViewed({ reportType, token });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', fire, { once: true });
    } else {
      fire();
    }
  </script>

  <footer class="du-share-footer">
    <div class="du-share-footer-inner">
      <h3>Read your own</h3>
      <p>Dear User reads your CLAUDE.md, skills, hooks and memory — then writes back what she saw. Runs locally, nothing leaves your machine.</p>
      <div class="install-inline">
        <span class="prompt">$</span>
        <span>claude mcp add --scope user dearuser -- npx @poisedhq/dearuser-mcp</span>
      </div>
      <div class="du-share-footer-links">
        <a href="https://dearuser.ai/">dearuser.ai</a>
        <a href="https://dearuser.ai/feedback">Got feedback?</a>
        <a href="https://dearuser.ai/example">See a full example</a>
      </div>
    </div>
  </footer>
</body>
</html>
