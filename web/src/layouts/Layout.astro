---
// Dear User — shared layout.
// Palette + fonts + light/dark + DA/EN toggles match the local dashboard
// (mcp/src/dashboard.ts) 1:1 so the public site and the product feel like
// one continuous surface.
import FeedbackModal from '../components/FeedbackModal.astro';
import Analytics from '@vercel/analytics/astro';
interface Props {
  title: string;
  description?: string;
  active?: 'home' | 'example' | 'demo' | 'feedback' | 'contact' | 'blog';
}
const {
  title,
  description = 'Understand how you and your AI agent actually work together. Dear User scans your setup and writes you a letter.',
  active = 'home',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://dearuser.ai').href;

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Dear User',
  url: 'https://dearuser.ai',
  description: 'Dear User scans your AI setup (agent rules, hooks, skills, scheduled jobs) and writes you a letter about how you and your agent actually work together.',
  logo: 'https://dearuser.ai/logo.svg',
  sameAs: [
    'https://github.com/bleedmode/dearuser',
    'https://x.com/dearuserai',
  ],
};

const siteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Dear User',
  url: 'https://dearuser.ai',
  description: 'A letter about how you and your AI agent work together.',
};
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Dear User" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@dearuserai" />
<meta name="twitter:creator" content="@dearuserai" />
<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(siteSchema)} />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 40 40'%3E%3Ccircle cx='20' cy='20' r='20' fill='%23EC5329'/%3E%3Cpath d='M 11 22 Q 20 32 29 22' stroke='%23FDFBF6' stroke-width='2.5' stroke-linecap='round' fill='none'/%3E%3C/svg%3E" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
<style is:global>
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }

  /* Light theme (default) — cream paper */
  :root {
    --c-paper-50:   #FDFBF6;
    --c-paper-100:  #F8F2E7;
    --c-paper-200:  #EFE4CF;
    --c-paper-300:  #D8C8A9;
    --c-ink-900:    #1F1A14;
    --c-ink-700:    #3E352A;
    --c-ink-500:    #72655B;
    --c-ink-400:    #A69989;
    --c-ink-300:    #AE9F91;
    --c-accent-600: #C3563B;
    --c-accent-500: #D77356;
    --c-accent-100: #F6E3D7;
    --c-action-700: #C93F1B;
    --c-action-600: #EC5329;
    --c-action-500: #F06B43;
    --c-action-100: #FCE5DB;
    --c-smile-fill: #FDFBF6;
    --c-good:       #059669;
    --c-warn:       #FBBF24;
    --c-bad:        #BE123C;
  }
  /* Dark theme — warm espresso, matches dashboard */
  html[data-theme="dark"] {
    --c-paper-50:   #1A1511;
    --c-paper-100:  #261F18;
    --c-paper-200:  #3A2F22;
    --c-paper-300:  #52422F;
    --c-ink-900:    #FFFAED;
    --c-ink-700:    #E5DBC3;
    --c-ink-500:    #A89A85;
    --c-ink-400:    #7E7162;
    --c-ink-300:    #5F5546;
    --c-accent-600: #E8725A;
    --c-accent-500: #F0896F;
    --c-accent-100: #3A241C;
    --c-action-700: #FF8560;
    --c-action-600: #FF7048;
    --c-action-500: #FF8F70;
    --c-action-100: #3D2218;
    --c-smile-fill: #1A1511;
    --c-good:       #34D399;
    --c-warn:       #FBBF24;
    --c-bad:        #F87171;
  }

  html { scroll-behavior: smooth; background: var(--c-paper-50); }
  body {
    font-family: 'Geist', system-ui, -apple-system, sans-serif;
    font-feature-settings: 'ss01';
    background: var(--c-paper-50);
    color: var(--c-ink-900);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
    transition: background-color 0.2s, color 0.2s;
  }
  a { color: inherit; }


  /* Shared primitives */
  .du-container { max-width: 1080px; margin: 0 auto; padding: 0 24px; }
  .du-narrow { max-width: 720px; margin: 0 auto; padding: 0 24px; }

  .du-header {
    background: color-mix(in srgb, var(--c-paper-50) 90%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--c-paper-200);
  }
  .du-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    max-width: 1080px;
    margin: 0 auto;
  }
  .du-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--c-ink-900);
  }
  .du-logo-mark {
    width: 26px; height: 26px;
    flex-shrink: 0;
  }
  .du-logo-name {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 20px;
    letter-spacing: -0.01em;
    font-weight: 500;
  }
  .du-logo-beta {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-style: normal;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-action-600);
    border: 1px solid var(--c-action-600);
    border-radius: 4px;
    padding: 2px 6px;
    margin-left: 4px;
    line-height: 1;
    align-self: center;
  }
  .du-nav {
    display: flex;
    align-items: center;
    gap: 22px;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .du-nav a {
    color: var(--c-ink-400);
    text-decoration: none;
    transition: color 0.15s;
  }
  .du-nav a:hover, .du-nav a.active { color: var(--c-ink-900); }
  .du-nav-sep { width: 1px; height: 16px; background: var(--c-paper-200); }
  .du-nav-btn {
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    color: var(--c-ink-400);
    font: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    display: inline-flex;
    align-items: center;
    transition: color 0.15s;
  }
  .du-nav-btn:hover { color: var(--c-ink-900); }

  .du-footer {
    border-top: 1px solid var(--c-paper-200);
    margin-top: 80px;
    padding: 56px 0 40px;
    color: var(--c-ink-500);
    font-size: 13px;
    background: linear-gradient(180deg, transparent 0%, color-mix(in srgb, var(--c-paper-100) 40%, transparent) 100%);
  }
  .du-footer-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 40px;
  }
  .du-footer-brand { max-width: 320px; }
  .du-footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--c-ink-900);
    margin-bottom: 14px;
  }
  .du-footer-logo-mark { width: 22px; height: 22px; flex-shrink: 0; }
  .du-footer-logo-name {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 18px;
    letter-spacing: -0.01em;
    font-weight: 500;
  }
  .du-footer-tagline {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-size: 15px;
    line-height: 1.5;
    color: var(--c-ink-500);
    margin: 0;
  }
  .du-footer-col-title {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ink-400);
    margin: 0 0 16px;
    font-weight: 500;
  }
  .du-footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .du-footer-col a {
    color: var(--c-ink-700);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .du-footer-col a:hover { color: var(--c-action-600); }
  .du-footer-col a .du-ext {
    width: 10px; height: 10px;
    opacity: 0.5;
    transition: opacity 0.15s;
  }
  .du-footer-col a:hover .du-ext { opacity: 1; }
  .du-footer-bottom {
    border-top: 1px solid var(--c-paper-200);
    padding-top: 24px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 12px;
    color: var(--c-ink-400);
  }
  .du-footer-sep {
    color: var(--c-ink-300);
    user-select: none;
  }
  .du-footer-made {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    color: var(--c-ink-500);
  }

  @media (max-width: 820px) {
    .du-footer-top {
      grid-template-columns: 1fr 1fr;
      gap: 36px 24px;
    }
    .du-footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 480px) {
    .du-footer { padding: 40px 0 32px; margin-top: 56px; }
    .du-footer-top { grid-template-columns: 1fr; gap: 28px; padding-bottom: 28px; }
    .du-footer-bottom { flex-direction: column; align-items: flex-start; gap: 12px; }
  }

  /* Mobile drawer toggle button — hidden on desktop */
  .du-mobile-toggle {
    display: none;
    background: transparent;
    border: 0;
    padding: 6px;
    margin: -6px;
    cursor: pointer;
    color: var(--c-ink-700);
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    transition: background-color 0.15s, color 0.15s;
  }
  .du-mobile-toggle:hover { color: var(--c-ink-900); background: var(--c-paper-100); }
  .du-mobile-toggle:focus-visible { outline: 2px solid var(--c-action-600); outline-offset: 2px; }

  /* Drawer + backdrop — only reachable via mobile hamburger */
  .du-drawer-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    z-index: 40;
  }
  .du-drawer-backdrop.is-open {
    opacity: 1;
    visibility: visible;
  }
  .du-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 280px;
    max-width: 82vw;
    background: var(--c-paper-50);
    border-left: 1px solid var(--c-paper-200);
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.08);
    transform: translateX(100%);
    transition: transform 0.25s ease;
    z-index: 50;
    display: flex;
    flex-direction: column;
    visibility: hidden;
  }
  .du-drawer.is-open {
    transform: translateX(0);
    visibility: visible;
  }
  .du-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid var(--c-paper-200);
  }
  .du-drawer-title {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-ink-400);
  }
  .du-drawer-close {
    background: transparent;
    border: 0;
    padding: 6px;
    margin: -6px;
    cursor: pointer;
    color: var(--c-ink-500);
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    transition: color 0.15s, background-color 0.15s;
  }
  .du-drawer-close:hover { color: var(--c-ink-900); background: var(--c-paper-100); }
  .du-drawer-nav {
    display: flex;
    flex-direction: column;
    padding: 12px 8px;
    gap: 2px;
  }
  .du-drawer-nav a {
    display: block;
    padding: 14px 16px;
    font-size: 15px;
    color: var(--c-ink-700);
    text-decoration: none;
    border-radius: 8px;
    transition: background-color 0.15s, color 0.15s;
  }
  .du-drawer-nav a:hover, .du-drawer-nav a.active {
    background: var(--c-paper-100);
    color: var(--c-ink-900);
  }
  .du-drawer-nav .du-drawer-sep {
    height: 1px;
    background: var(--c-paper-200);
    margin: 8px 16px;
  }

  /* On mobile: swap horizontal nav links for hamburger; keep toggles in topbar */
  @media (max-width: 640px) {
    .du-nav a { display: none; }
    .du-nav { gap: 14px; }
    .du-mobile-toggle { display: inline-flex; }
  }
</style>
</head>
<body>
  <header class="du-header">
    <div class="du-header-inner">
      <a href="/" class="du-logo" aria-label="Dear User home">
        <svg class="du-logo-mark" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="20" cy="20" r="20" fill="#EC5329" />
          <path d="M 11 22 Q 20 32 29 22" stroke="var(--c-smile-fill)" stroke-width="2.5" stroke-linecap="round" fill="none" />
        </svg>
        <span class="du-logo-name">Dear User</span>
        <span class="du-logo-beta" aria-label="Beta">beta</span>
      </a>
      <nav class="du-nav">
        <a href="/#features" data-nav="features">
          Features
        </a>
        <a href="/example" class={active === 'example' ? 'active' : ''}>
          Example
        </a>
        <a href="/demo" class={active === 'demo' ? 'active' : ''}>
          Wrapped
        </a>
        <a href="/blog" class={active === 'blog' ? 'active' : ''}>
          Blog
        </a>
        <a href="https://github.com/bleedmode/dearuser" target="_blank" rel="noopener">GitHub</a>
        <a href="/feedback" class={`${active === 'feedback' ? 'active' : ''}`} data-open-feedback aria-label="Send feedback">
          Feedback
        </a>
        <span class="du-nav-sep" aria-hidden="true"></span>
        <button id="du-theme-toggle" class="du-nav-btn" aria-label="Toggle theme">
          <svg id="du-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
          <svg id="du-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button id="du-mobile-toggle" class="du-mobile-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="du-drawer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </nav>
    </div>
  </header>

  <div id="du-drawer-backdrop" class="du-drawer-backdrop" aria-hidden="true"></div>
  <aside id="du-drawer" class="du-drawer" aria-hidden="true" aria-label="Site menu">
    <div class="du-drawer-header">
      <span class="du-drawer-title">
        Menu
      </span>
      <button id="du-drawer-close" class="du-drawer-close" aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <nav class="du-drawer-nav" aria-label="Mobile navigation">
      <a href="/#features">
        Features
      </a>
      <a href="/example" class={active === 'example' ? 'active' : ''}>
        Example
      </a>
      <a href="/demo" class={active === 'demo' ? 'active' : ''}>
        Wrapped
      </a>
      <a href="/blog" class={active === 'blog' ? 'active' : ''}>
        Blog
      </a>
      <a href="https://github.com/bleedmode/dearuser" target="_blank" rel="noopener">GitHub</a>
      <span class="du-drawer-sep" aria-hidden="true"></span>
      <a href="/feedback" class={active === 'feedback' ? 'active' : ''} data-open-feedback aria-label="Send feedback">
        Feedback
      </a>
    </nav>
  </aside>

  <slot />

  {active !== 'feedback' && active !== 'contact' && <FeedbackModal mode="modal" defaultContext="general" />}

  <Analytics />

  <script>
    // Website analytics — dearuser.ai only. MCP/dashboard never tracked.
    // See src/lib/analytics.ts for the full privacy contract.
    import { initAnalytics, trackLandingViewed } from '../lib/analytics';
    initAnalytics();
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', trackLandingViewed, { once: true });
    } else {
      trackLandingViewed();
    }
  </script>

  <footer class="du-footer">
    <div class="du-container">
      <div class="du-footer-top">
        <div class="du-footer-brand">
          <a href="/" class="du-footer-logo" aria-label="Dear User home">
            <svg class="du-footer-logo-mark" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="20" cy="20" r="20" fill="#EC5329" />
              <path d="M 11 22 Q 20 32 29 22" stroke="var(--c-smile-fill)" stroke-width="2.5" stroke-linecap="round" fill="none" />
            </svg>
            <span class="du-footer-logo-name">Dear User</span>
          </a>
          <p class="du-footer-tagline">
            
            Understand how you and your AI agent actually work together — in a letter you can read in two minutes.
          </p>
        </div>

        <div class="du-footer-col">
          <h4 class="du-footer-col-title">
            Product
          </h4>
          <ul>
            <li><a href="/#install">
              Get started
            </a></li>
            <li><a href="/#features">
              Features
            </a></li>
            <li><a href="/example">
              Example letter
            </a></li>
            <li><a href="/demo">
              Wrapped
            </a></li>
            <li><a href="/blog">
              Blog
            </a></li>
          </ul>
        </div>

        <div class="du-footer-col">
          <h4 class="du-footer-col-title">
            Contact
          </h4>
          <ul>
            <li><a href="/contact">
              Write to us
            </a></li>
            <li><a href="/feedback">
              Feedback
            </a></li>
            <li><a href="https://github.com/bleedmode/dearuser/discussions" target="_blank" rel="noopener">
              GitHub Discussions
            </a></li>
            <li><a href="https://github.com/bleedmode/dearuser" target="_blank" rel="noopener">
              GitHub
            </a></li>
            <li><a href="https://x.com/dearuserai" target="_blank" rel="noopener">
              X (@dearuserai)
            </a></li>
          </ul>
        </div>
      </div>

      <div class="du-footer-bottom">
        <span>© 2026 Dear User</span>
        <span class="du-footer-sep" aria-hidden="true">·</span>
        <a href="/privacy" style="color: var(--c-ink-500); text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--c-action-600)'" onmouseout="this.style.color='var(--c-ink-500)'">
          Privacy
        </a>
        <span class="du-footer-sep" aria-hidden="true">·</span>
        <span class="du-footer-made">
          
          Privacy-first — no cookies, no cross-session tracking.
        </span>
      </div>
    </div>
  </footer>

  <script is:inline>
    (function () {
      var html = document.documentElement;
      var savedTheme = localStorage.getItem('dearuser-theme');
      var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
      var theme = savedTheme || (prefersDark ? 'dark' : 'light');
      if (theme === 'dark') html.setAttribute('data-theme', 'dark');

      function syncIcons() {
        var isDark = html.getAttribute('data-theme') === 'dark';
        var sun = document.getElementById('du-sun');
        var moon = document.getElementById('du-moon');
        if (sun) sun.style.display = isDark ? 'none' : 'block';
        if (moon) moon.style.display = isDark ? 'block' : 'none';
      }

      document.addEventListener('DOMContentLoaded', function () {
        syncIcons();

        var t = document.getElementById('du-theme-toggle');
        if (t) t.addEventListener('click', function () {
          var isDark = html.getAttribute('data-theme') === 'dark';
          if (isDark) { html.removeAttribute('data-theme'); localStorage.setItem('dearuser-theme', 'light'); }
          else { html.setAttribute('data-theme', 'dark'); localStorage.setItem('dearuser-theme', 'dark'); }
          syncIcons();
        });

        // Mobile drawer: hamburger toggle, backdrop click, ESC, link click
        var drawer = document.getElementById('du-drawer');
        var backdrop = document.getElementById('du-drawer-backdrop');
        var mobileToggle = document.getElementById('du-mobile-toggle');
        var drawerClose = document.getElementById('du-drawer-close');
        function setDrawerOpen(open) {
          if (!drawer || !backdrop || !mobileToggle) return;
          if (open) {
            drawer.classList.add('is-open');
            backdrop.classList.add('is-open');
            mobileToggle.setAttribute('aria-expanded', 'true');
            drawer.setAttribute('aria-hidden', 'false');
            backdrop.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
          } else {
            drawer.classList.remove('is-open');
            backdrop.classList.remove('is-open');
            mobileToggle.setAttribute('aria-expanded', 'false');
            drawer.setAttribute('aria-hidden', 'true');
            backdrop.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
          }
        }
        if (mobileToggle) mobileToggle.addEventListener('click', function () {
          setDrawerOpen(!drawer.classList.contains('is-open'));
        });
        if (drawerClose) drawerClose.addEventListener('click', function () { setDrawerOpen(false); });
        if (backdrop) backdrop.addEventListener('click', function () { setDrawerOpen(false); });
        if (drawer) drawer.addEventListener('click', function (e) {
          var link = e.target && e.target.closest ? e.target.closest('a') : null;
          if (link) setDrawerOpen(false);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && drawer && drawer.classList.contains('is-open')) {
            setDrawerOpen(false);
          }
        });
        // Reset drawer state when crossing back to desktop width
        var mq = window.matchMedia('(min-width: 641px)');
        mq.addEventListener('change', function (e) {
          if (e.matches) setDrawerOpen(false);
        });

        // Scroll-spy: toggle the Features nav link only when the
        // #features section is actually in view on the landing page.
        var featuresSection = document.getElementById('features');
        var featuresLink = document.querySelector('[data-nav="features"]');
        if (featuresSection && featuresLink && 'IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) featuresLink.classList.add('active');
              else featuresLink.classList.remove('active');
            });
          }, { rootMargin: '-80px 0px -40% 0px', threshold: 0 });
          io.observe(featuresSection);
        }
      });
    })();
  </script>
</body>
</html>
