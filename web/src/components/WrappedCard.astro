---
// WrappedCard — renders the shared Wrapped scroll-through on /r/<token>.
//
// Visual + slide logic live in ../lib/wrapped-slides.ts so the dashboard
// (localhost:7700/wrapped) and the share page look identical — one source
// of truth, no drift.

import { renderWrappedSlides, type WrappedDataInput, type WrappedMomentInput } from '../lib/wrapped-slides.ts';

interface Props {
  projectName: string;
  score: number | null;
  createdAt: string;
  wrapped: WrappedDataInput;
  setupArchetypeName?: string | null;
  moments?: WrappedMomentInput[];
}

const { projectName, score, createdAt, wrapped, setupArchetypeName, moments } = Astro.props;
const year = new Date(createdAt).getFullYear();

const html = renderWrappedSlides({
  score,
  year,
  projectName,
  wrapped,
  moments,
  setupArchetypeName: setupArchetypeName || null,
  showShareCta: true,
  mode: 'shared',
});
---

<Fragment set:html={html} />
