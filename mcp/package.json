{
  "name": "@poisedhq/dearuser-mcp",
  "version": "1.0.16",
  "mcpName": "io.github.bleedmode/dearuser",
  "publishConfig": {
    "access": "public"
  },
  "description": "Dear User — helps humans and AI agents understand each other better",
  "type": "module",
  "bin": {
    "dearuser-mcp": "./dist/index.js",
    "dearuser-dashboard": "./dist/dashboard-standalone.js",
    "dearuser-run": "./dist/run-tool.js",
    "dearuser-install-skills": "./dist/install-skills.js"
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "build:types": "tsc --noEmit",
    "build:reload": "node esbuild.config.js && bash scripts/reload-dashboard.sh",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:any": "node scripts/lint-any-count.js",
    "dashboard:reload": "bash scripts/reload-dashboard.sh",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "skills",
    "data",
    "migrations",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "claude-desktop",
    "ai-agent",
    "collaboration",
    "developer-tools",
    "local-first",
    "dearuser",
    "agent-wrapped"
  ],
  "author": "Poised ApS",
  "license": "MIT",
  "homepage": "https://dearuser.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bleedmode/dearuser.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/bleedmode/dearuser/issues"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^12.9.0",
    "hono": "^4.12.14",
    "marked": "^18.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
